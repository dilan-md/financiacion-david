---
---

<div id="calendar-widget-container" class="bg-white dark:bg-[#111111] rounded-3xl p-6 shadow-card border border-slate-100 dark:border-[#222222] transition-colors overflow-hidden h-full">
    <div id="calendar-view">
        <div class="flex justify-between items-center mb-6">
            <h2 id="calendar-month-year" class="text-xl font-bold text-slate-dark dark:text-white"></h2>
            <div class="flex gap-2">
                <button id="prev-month" class="p-2 hover:bg-slate-100 dark:hover:bg-slate-800 rounded-lg text-slate-500 transition-colors">
                    <span class="material-symbols-outlined text-xl">chevron_left</span>
                </button>
                <button id="next-month" class="p-2 hover:bg-slate-100 dark:hover:bg-slate-800 rounded-lg text-slate-500 transition-colors">
                    <span class="material-symbols-outlined text-xl">chevron_right</span>
                </button>
            </div>
        </div>

        <div class="grid grid-cols-7 gap-1 mb-2">
            {['S', 'M', 'T', 'W', 'T', 'F', 'S'].map(d => (
                <div class="text-center text-[10px] font-bold text-slate-400 uppercase tracking-widest py-2">
                    {d}
                </div>
            ))}
        </div>

        <div id="calendar-days" class="grid grid-cols-7 gap-1">
            <!-- Days will be injected here -->
        </div>
    </div>
</div>

<script>
    import { getTransactions, getCalendarNotes, getGoals } from "../utils/store";

    let currentDate = new Date();
    let selectedDate: Date | null = null;
    let transactions: any[] = [];
    let calendarNotes: any[] = [];
    let goals: any[] = [];

    async function initCalendar() {
        const daysContainer = document.getElementById('calendar-days');
        const monthYearEl = document.getElementById('calendar-month-year');
        const prevBtn = document.getElementById('prev-month');
        const nextBtn = document.getElementById('next-month');

        if (!daysContainer || !monthYearEl) return;

        // Fetch data
        [transactions, calendarNotes, goals] = await Promise.all([
            getTransactions(),
            getCalendarNotes(),
            getGoals()
        ]);

        function renderCalendar() {
            const year = currentDate.getFullYear();
            const month = currentDate.getMonth();
            
            const firstDay = new Date(year, month, 1).getDay();
            const lastDate = new Date(year, month + 1, 0).getDate();
            const prevLastDate = new Date(year, month, 0).getDate();
            
            monthYearEl!.textContent = currentDate.toLocaleDateString('default', { month: 'long', year: 'numeric' });
            
            let daysHtml = '';
            
            // Previous month days
            for (let i = firstDay; i > 0; i--) {
                daysHtml += `<div class="p-2 text-center text-slate-300 dark:text-slate-700 text-sm opacity-40">${prevLastDate - i + 1}</div>`;
            }
            
            // Current month days
            const today = new Date();
            for (let i = 1; i <= lastDate; i++) {
                const dateKey = `${year}-${String(month + 1).padStart(2, '0')}-${String(i).padStart(2, '0')}`;
                
                const dayTransactions = transactions.filter(t => t.date === dateKey);
                const dayNotes = calendarNotes.filter(n => n.date === dateKey);
                const dayGoals = goals.filter(g => g.date === dateKey);
                
                const isToday = today.getDate() === i && today.getMonth() === month && today.getFullYear() === year;
                const isSelected = selectedDate?.getDate() === i && selectedDate?.getMonth() === month && selectedDate?.getFullYear() === year;
                
                const hasTransactions = dayTransactions.length > 0;
                const hasNotes = dayNotes.length > 0;
                const hasGoal = dayGoals.length > 0;

                let classes = 'relative p-2 text-center text-sm font-medium rounded-xl cursor-pointer transition-all hover:bg-indigo/10 dark:hover:bg-indigo/20 ';
                
                if (isToday) {
                    classes += 'bg-indigo text-white shadow-sm ring-2 ring-indigo ring-offset-2 dark:ring-offset-[#111111] ';
                } else if (isSelected) {
                    classes += 'bg-indigo/20 text-indigo border-2 border-indigo ';
                } else if (hasNotes) {
                    classes += 'border-2 border-indigo dark:border-indigo/50 text-indigo dark:text-indigo-400 ';
                } else {
                    classes += 'text-slate-600 dark:text-slate-400 ';
                }

                daysHtml += `
                    <div class="${classes.trim()}" data-day="${i}">
                        ${i}
                        ${hasTransactions ? '<div class="absolute bottom-1 left-1/4 -translate-x-1/2 w-1 h-1 bg-teal rounded-full text-[6px]"></div>' : ''}
                        ${hasGoal ? '<div class="absolute bottom-1 left-3/4 -translate-x-1/2 w-1 h-1 bg-orange rounded-full"></div>' : ''}
                        ${hasNotes && !isToday ? '<div class="absolute top-1 right-1 w-1.5 h-1.5 bg-indigo rounded-full animate-pulse"></div>' : ''}
                        ${hasGoal && !isToday ? '<span class="material-symbols-outlined absolute -top-1 -left-1 text-[10px] text-orange">flag</span>' : ''}
                    </div>
                `;
            }
            
            daysContainer!.innerHTML = daysHtml;

            // Add click events to days
            daysContainer!.querySelectorAll('[data-day]').forEach(dayEl => {
                dayEl.addEventListener('click', () => {
                    const day = parseInt((dayEl as HTMLElement).dataset.day!);
                    selectedDate = new Date(year, month, day);
                    
                    const dateKey = `${year}-${String(month + 1).padStart(2, '0')}-${String(day).padStart(2, '0')}`;
                    window.dispatchEvent(new CustomEvent('calendar-date-selected', { 
                        detail: { date: dateKey, displayDate: selectedDate.toLocaleDateString('default', { weekday: 'short', day: 'numeric', month: 'short' }) } 
                    }));
                    
                    renderCalendar();
                });
            });
        }

        prevBtn?.addEventListener('click', () => {
            currentDate.setMonth(currentDate.getMonth() - 1);
            renderCalendar();
        });

        nextBtn?.addEventListener('click', () => {
            currentDate.setMonth(currentDate.getMonth() + 1);
            renderCalendar();
        });

        renderCalendar();
    }

    document.addEventListener('astro:page-load', initCalendar);
    window.addEventListener('transactions-updated', initCalendar);
    window.addEventListener('calendar-notes-updated', initCalendar);
    window.addEventListener('goals-updated', initCalendar);
</script>
</script>

<style>
    #calendar-widget-container {
        height: min-content;
    }
    .animate-fade-in {
        animation: fadeIn 0.3s ease-out;
    }
    @keyframes fadeIn {
        from { opacity: 0; transform: translateY(-10px); }
        to { opacity: 1; transform: translateY(0); }
    }
</style>
