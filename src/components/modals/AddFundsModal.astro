---

---

<dialog
    id="add-funds-modal"
    class="backdrop:bg-slate-dark/40 backdrop:backdrop-blur-sm rounded-3xl p-0 border-0 shadow-floating fixed inset-0 m-auto open:animate-fade-in w-full max-w-sm bg-transparent"
>
    <div
        class="bg-white rounded-3xl flex flex-col h-full overflow-hidden border border-slate-100 shadow-xl"
    >
        <header
            class="flex justify-between items-center p-6 border-b border-slate-100 bg-teal/5"
        >
            <div>
                <h2 class="text-2xl font-bold text-slate-dark tracking-tight">
                    Add Funds
                </h2>
                <p
                    id="fund-goal-name"
                    class="text-slate-500 font-medium text-sm mt-1"
                >
                    Saving for: ...
                </p>
            </div>
            <button
                id="close-funds-modal"
                class="text-slate-400 hover:text-teal hover:bg-slate-100 w-10 h-10 rounded-full flex items-center justify-center transition-colors"
            >
                <span class="material-symbols-outlined">close</span>
            </button>
        </header>

        <form id="funds-form" class="p-6">
            <input type="hidden" id="fund-goal-id" name="goalId" />

            <div class="mb-8">
                <label
                    for="fund-amount"
                    class="block text-sm font-bold text-slate-500 uppercase tracking-wider mb-2"
                    >Amount to add</label
                >
                <div class="relative">
                    <span
                        class="absolute inset-y-0 left-0 pl-4 flex items-center text-slate-400 font-mono text-xl"
                        >$</span
                    >
                    <input
                        type="number"
                        id="fund-amount"
                        name="amount"
                        placeholder="0"
                        step="1"
                        min="1"
                        required
                        class="w-full py-4 pl-12 pr-4 rounded-xl border-2 border-slate-200 focus:border-teal focus:ring-0 text-slate-dark font-mono text-2xl font-bold bg-white transition-colors placeholder-slate-300"
                    />
                </div>
            </div>

            <button
                type="submit"
                class="w-full py-4 rounded-xl text-white font-bold text-lg bg-teal hover:bg-teal-600 transition-colors shadow-tactile hover:shadow-tactile-hover translate-y-0 hover:translate-y-[1px]"
            >
                Confirm Deposit
            </button>
        </form>
    </div>
</dialog>

<script>
    import { updateGoalProgress, getGoals } from "../../utils/store";

    function initFundsModal() {
        const modal = document.getElementById(
            "add-funds-modal",
        ) as HTMLDialogElement;
        const form = document.getElementById("funds-form") as HTMLFormElement;
        const closeBtn = document.getElementById("close-funds-modal");
        const goalNameEl = document.getElementById("fund-goal-name");
        const goalIdInput = document.getElementById(
            "fund-goal-id",
        ) as HTMLInputElement;

        if (!modal || !form || !closeBtn) return;

        (window as any).openAddFundsModal = (goalId: string) => {
            const goals = getGoals();
            const goal = goals.find((g) => g.id === goalId);
            if (!goal) return;

            if (goalNameEl) goalNameEl.textContent = `Saving for: ${goal.name}`;
            if (goalIdInput) goalIdInput.value = goalId;

            modal.showModal();
        };

        closeBtn.addEventListener("click", () => {
            modal.close();
            form.reset();
        });

        // Close on backdrop click
        modal.addEventListener("click", (e) => {
            const rect = modal.getBoundingClientRect();
            const isInDialog =
                rect.top <= e.clientY &&
                e.clientY <= rect.top + rect.height &&
                rect.left <= e.clientX &&
                e.clientX <= rect.left + rect.width;
            if (!isInDialog) {
                modal.close();
                form.reset();
            }
        });

        form.addEventListener("submit", (e) => {
            e.preventDefault();
            const formData = new FormData(form);
            const goalId = formData.get("goalId") as string;
            const amount = parseFloat(formData.get("amount") as string);

            if (goalId && amount > 0) {
                updateGoalProgress(goalId, amount);
                modal.close();
                form.reset();
            }
        });
    }

    document.addEventListener("astro:page-load", initFundsModal);
</script>

<style>
    .bg-teal {
        background-color: #0d9488;
    }
    .text-teal {
        color: #0d9488;
    }
    .hover\:text-teal:hover {
        color: #0d9488;
    }
    .focus\:border-teal:focus {
        border-color: #0d9488;
    }
    .bg-teal-600 {
        background-color: #0d9488;
    }
</style>
