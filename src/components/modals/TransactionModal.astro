---

---

<dialog
    id="transaction-modal"
    class="backdrop:bg-slate-dark/40 backdrop:backdrop-blur-sm rounded-3xl p-0 border-0 shadow-floating fixed inset-0 m-auto open:animate-fade-in w-full max-w-md bg-transparent"
>
    <div
        class="bg-white rounded-3xl flex flex-col h-full overflow-hidden border border-slate-100 shadow-xl"
    >
        <header
            class="flex justify-between items-center p-6 border-b border-slate-100"
        >
            <h2
                id="transaction-modal-title"
                class="text-2xl font-bold text-slate-dark tracking-tight"
            >
                Add Transaction
            </h2>
            <button
                id="close-transaction-modal"
                class="text-slate-400 hover:text-slate-600 hover:bg-slate-50 w-10 h-10 rounded-full flex items-center justify-center transition-colors"
            >
                <span class="material-symbols-outlined">close</span>
            </button>
        </header>

        <form id="transaction-form" class="p-6 flex-1 overflow-y-auto">
            <div class="flex p-1 bg-slate-100 rounded-xl mb-6">
                <button
                    type="button"
                    id="tab-expense"
                    class="flex-1 py-2 text-center text-sm font-bold rounded-lg bg-orange text-white shadow-sm transition-all"
                    >Expense</button
                >
                <button
                    type="button"
                    id="tab-income"
                    class="flex-1 py-2 text-center text-sm font-bold rounded-lg text-slate-500 hover:text-slate-700 transition-all"
                    >Income</button
                >
            </div>

            <input type="hidden" id="transaction-id" name="id" value="" />

            <input
                type="hidden"
                id="transaction-type"
                name="type"
                value="expense"
            />

            <div class="mb-5">
                <label
                    for="amount"
                    class="block text-sm font-bold text-slate-500 uppercase tracking-wider mb-2"
                    >Amount</label
                >
                <div class="relative">
                    <span
                        class="absolute inset-y-0 left-0 pl-4 flex items-center text-slate-400 font-mono text-xl"
                        >$</span
                    >
                    <input
                        type="number"
                        id="amount"
                        name="amount"
                        placeholder="0"
                        step="1"
                        min="0"
                        required
                        class="w-full py-4 pl-12 pr-4 rounded-xl border-2 border-slate-200 focus:border-indigo focus:ring-0 text-slate-dark font-mono text-2xl font-bold bg-white transition-colors placeholder-slate-300"
                    />
                </div>
            </div>

            <div class="mb-5">
                <label
                    for="category"
                    class="block text-sm font-bold text-slate-500 uppercase tracking-wider mb-2"
                    >Category</label
                >
                <div class="relative">
                    <select
                        id="category"
                        name="category"
                        class="w-full appearance-none py-3 pl-4 pr-12 rounded-xl border-2 border-slate-200 focus:border-indigo focus:ring-0 text-slate-dark font-medium bg-white transition-colors cursor-pointer"
                    >
                        <option value="food">🍱 Dining & Food</option>
                        <option value="shopping">🛍️ Shopping</option>
                        <option value="transportation">🚗 Transportation</option
                        >
                        <option value="bills">⚡ Utilities & Bills</option>
                        <option value="entertainment">🎬 Entertainment</option>
                        <option value="other">📦 Other</option>
                    </select>
                    <span
                        class="absolute inset-y-0 right-0 pr-4 flex items-center text-slate-400 pointer-events-none"
                    >
                        <span class="material-symbols-outlined"
                            >expand_more</span
                        >
                    </span>
                </div>
            </div>

            <div class="mb-5">
                <label
                    for="date"
                    class="block text-sm font-bold text-slate-500 uppercase tracking-wider mb-2"
                    >Date</label
                >
                <input
                    type="date"
                    id="date"
                    name="date"
                    required
                    class="w-full py-3 px-4 rounded-xl border-2 border-slate-200 focus:border-indigo focus:ring-0 text-slate-dark font-medium bg-white transition-colors"
                />
            </div>

            <div class="mb-8">
                <label
                    for="note"
                    class="block text-sm font-bold text-slate-500 uppercase tracking-wider mb-2"
                    >Note (Optional)</label
                >
                <input
                    type="text"
                    id="note"
                    name="note"
                    placeholder="e.g. Dinner with friends"
                    class="w-full py-3 px-4 rounded-xl border-2 border-slate-200 focus:border-indigo focus:ring-0 text-slate-dark font-medium bg-white transition-colors placeholder-slate-300"
                />
            </div>

            <div class="flex flex-col gap-3">
                <button
                    type="submit"
                    id="submit-transaction-btn"
                    class="w-full py-4 rounded-xl text-white font-bold text-lg bg-orange hover:opacity-90 transition-opacity shadow-tactile hover:shadow-tactile-hover translate-y-0 hover:translate-y-[1px]"
                >
                    Add Expense
                </button>
                <button
                    type="button"
                    id="delete-transaction-btn"
                    class="hidden w-full py-3 rounded-xl text-orange-600 font-bold text-sm bg-orange-50 hover:bg-orange-100 transition-colors"
                >
                    Delete Transaction
                </button>
            </div>
        </form>
    </div>
</dialog>

<script>
    import {
        addTransaction,
        getTransactions,
        updateTransaction,
        deleteTransaction,
        isUserAdmin,
    } from "../../utils/store";

    document.addEventListener("astro:page-load", () => {
        const modal = document.getElementById(
            "transaction-modal",
        ) as HTMLDialogElement;
        const closeModalBtn = document.getElementById(
            "close-transaction-modal",
        );
        const form = document.getElementById(
            "transaction-form",
        ) as HTMLFormElement;

        // Tab switching elements
        const tabExpense = document.getElementById("tab-expense");
        const tabIncome = document.getElementById("tab-income");
        const typeInput = document.getElementById(
            "transaction-type",
        ) as HTMLInputElement;
        let currentType: "expense" | "income" = "expense";
        const submitBtn = document.getElementById("submit-transaction-btn");
        const title = document.getElementById("transaction-modal-title");
        const categorySelect = document.getElementById(
            "category",
        ) as HTMLSelectElement;
        const idInput = document.getElementById(
            "transaction-id",
        ) as HTMLInputElement;
        const deleteBtn = document.getElementById("delete-transaction-btn");
        const amountInput = document.getElementById(
            "amount",
        ) as HTMLInputElement;
        const noteInput = document.getElementById("note") as HTMLInputElement;
        const dateInput = document.getElementById("date") as HTMLInputElement;

        // Ensure we only bind if the elements exist on the current page
        if (!modal || !form) return;

        const incomeCategories = [
            '<option value="salary">💼 Salary & Wages</option>',
            '<option value="freelance">💻 Freelance</option>',
            '<option value="investments">📈 Investments</option>',
            '<option value="other_income">🎁 Other Income</option>',
        ].join("");

        const expenseCategories = [
            '<option value="food">🍱 Dining & Food</option>',
            '<option value="shopping">🛍️ Shopping</option>',
            '<option value="transportation">🚗 Transportation</option>',
            '<option value="bills">⚡ Utilities & Bills</option>',
            '<option value="entertainment">🎬 Entertainment</option>',
            '<option value="other">📦 Other</option>',
        ].join("");

        function setType(type: "expense" | "income") {
            currentType = type;
            typeInput.value = type;
            if (type === "expense") {
                tabExpense?.classList.add(
                    "bg-orange",
                    "text-white",
                    "shadow-sm",
                );
                tabExpense?.classList.remove(
                    "text-slate-500",
                    "hover:text-slate-700",
                );
                tabIncome?.classList.add(
                    "text-slate-500",
                    "hover:text-slate-700",
                );
                tabIncome?.classList.remove(
                    "bg-indigo",
                    "text-white",
                    "shadow-sm",
                );

                if (submitBtn) {
                    submitBtn.textContent = idInput.value
                        ? "Save Changes"
                        : "Add Expense";
                    submitBtn.className =
                        "w-full py-4 rounded-xl text-white font-bold text-lg bg-orange hover:opacity-90 transition-opacity shadow-tactile hover:shadow-tactile-hover translate-y-0 hover:translate-y-[1px]";
                }
                if (title)
                    title.textContent = idInput.value
                        ? "Edit Expense"
                        : "Add Expense";
                if (categorySelect)
                    categorySelect.innerHTML = expenseCategories;
            } else {
                tabIncome?.classList.add(
                    "bg-indigo",
                    "text-white",
                    "shadow-sm",
                );
                tabIncome?.classList.remove(
                    "text-slate-500",
                    "hover:text-slate-700",
                );
                tabExpense?.classList.add(
                    "text-slate-500",
                    "hover:text-slate-700",
                );
                tabExpense?.classList.remove(
                    "bg-orange",
                    "text-white",
                    "shadow-sm",
                );

                if (submitBtn) {
                    submitBtn.textContent = idInput.value
                        ? "Save Changes"
                        : "Add Income";
                    submitBtn.className =
                        "w-full py-4 rounded-xl text-white font-bold text-lg bg-indigo hover:opacity-90 transition-opacity shadow-tactile hover:shadow-tactile-hover translate-y-0 hover:translate-y-[1px]";
                }
                if (title)
                    title.textContent = idInput.value
                        ? "Edit Income"
                        : "Add Income";
                if (categorySelect) categorySelect.innerHTML = incomeCategories;
            }

            if (idInput.value) {
                deleteBtn?.classList.remove("hidden");
            } else {
                deleteBtn?.classList.add("hidden");
            }
        }

        tabExpense?.addEventListener("click", () => setType("expense"));
        tabIncome?.addEventListener("click", () => setType("income"));

        // Set today as default date
        if (dateInput) {
            dateInput.valueAsDate = new Date();
        }

        // Delete confirm
        deleteBtn?.addEventListener("click", () => {
            if (confirm("Are you sure you want to delete this transaction?")) {
                const id = idInput.value;
                if (id) {
                    deleteTransaction(id);
                    modal.close();
                }
            }
        });

        // Close logic
        closeModalBtn?.addEventListener("click", () => {
            modal.close();
            form.reset();
            idInput.value = "";
            // Reset to expense by default on close
            setType("expense");
            if (dateInput) dateInput.valueAsDate = new Date();
        });

        // Close on backdrop click
        modal?.addEventListener("click", (e) => {
            const dialogDimensions = modal.getBoundingClientRect();
            if (
                e.clientX < dialogDimensions.left ||
                e.clientX > dialogDimensions.right ||
                e.clientY < dialogDimensions.top ||
                e.clientY > dialogDimensions.bottom
            ) {
                modal.close();
                form.reset();
                idInput.value = "";
                setType("expense");
                if (dateInput) dateInput.valueAsDate = new Date();
            }
        });

        // Handle form submission
        form?.addEventListener("submit", async (e) => {
            e.preventDefault();

            const btn = submitBtn as HTMLButtonElement;
            if (btn) {
                const originalText = btn.textContent;
                btn.disabled = true;
                btn.innerHTML =
                    '<span class="animate-spin material-symbols-outlined">progress_activity</span> Saving...';

                try {
                    const formData = new FormData(form);
                    const data = Object.fromEntries(formData.entries());
                    const id = idInput.value;

                    const transactionData = {
                        type:
                            (data.type as "expense" | "income") || currentType,
                        amount: parseFloat(data.amount as string) || 0,
                        category: (data.category as string) || "other",
                        date: data.date as string,
                        note: data.note as string,
                    };

                    if (id) {
                        await updateTransaction(id, transactionData);
                    } else {
                        await addTransaction(transactionData);
                    }

                    modal.close();
                    form.reset();
                    idInput.value = "";
                    setType("expense");
                    if (dateInput) dateInput.valueAsDate = new Date();
                } catch (error) {
                    console.error("Error saving transaction:", error);
                    alert("Error saving transaction. Please try again.");
                } finally {
                    if (btn) {
                        btn.disabled = false;
                        btn.textContent = originalText;
                    }
                }
            }
        });

        // Expose open method globally to be called from other components
        (window as any).openTransactionModal = async (
            typeOrId: "expense" | "income" | string = "expense",
        ) => {
            const isAdmin = await isUserAdmin();
            if (submitBtn)
                (submitBtn as HTMLElement).style.display = isAdmin
                    ? "block"
                    : "none";
            if (deleteBtn)
                (deleteBtn as HTMLElement).style.display = isAdmin
                    ? "block"
                    : "none";

            form.reset();

            if (typeOrId !== "expense" && typeOrId !== "income") {
                // It's an ID for editing
                const transactions = await getTransactions();
                const t = transactions.find(
                    (item: any) => item.id === typeOrId,
                );
                if (t) {
                    idInput.value = t.id;
                    setType(t.type);
                    amountInput.value = t.amount.toString();
                    categorySelect.value = t.category;
                    dateInput.value = t.date;
                    noteInput.value = t.note;
                }
            } else {
                // It's a new transaction type
                idInput.value = "";
                setType(typeOrId as "expense" | "income");
                if (dateInput) dateInput.valueAsDate = new Date();
            }

            modal.showModal();
        };
    });
</script>

<style>
    /* Prevent scrolling on the body when modal is open */
    :global(body:has(dialog[open])) {
        overflow: hidden;
    }
</style>
