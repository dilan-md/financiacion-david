---

---

<dialog
    id="goal-modal"
    class="backdrop:bg-slate-dark/40 backdrop:backdrop-blur-sm rounded-3xl p-0 border-0 shadow-floating fixed inset-0 m-auto open:animate-fade-in w-full max-w-md bg-transparent"
>
    <div
        class="bg-white rounded-3xl flex flex-col h-full overflow-hidden border border-slate-100 shadow-xl"
    >
        <header
            class="flex justify-between items-center p-6 border-b border-slate-100 bg-indigo-bg/30"
        >
            <div>
                <h2 class="text-2xl font-bold text-slate-dark tracking-tight">
                    New Savings Goal
                </h2>
                <p class="text-slate-500 font-medium text-sm mt-1">
                    What are we saving for?
                </p>
            </div>
            <button
                id="close-goal-modal"
                class="text-slate-400 hover:text-indigo hover:bg-slate-100 w-10 h-10 rounded-full flex items-center justify-center transition-colors"
            >
                <span class="material-symbols-outlined">close</span>
            </button>
        </header>

        <form id="goal-form" class="p-6 flex-1 overflow-y-auto">
            <input type="hidden" id="goal-id" name="id" />
            <div class="mb-5">
                <label
                    for="goal-name"
                    class="block text-sm font-bold text-slate-500 uppercase tracking-wider mb-2"
                    >Goal Name</label
                >
                <input
                    type="text"
                    id="goal-name"
                    name="name"
                    placeholder="e.g. Dream Vacation"
                    required
                    class="w-full py-3 px-4 rounded-xl border-2 border-slate-200 focus:border-indigo focus:ring-0 text-slate-dark font-medium bg-white transition-colors placeholder-slate-300"
                />
            </div>

            <div class="mb-5">
                <label
                    for="target-amount"
                    class="block text-sm font-bold text-slate-500 uppercase tracking-wider mb-2"
                    >Target Amount</label
                >
                <div class="relative">
                    <span
                        class="absolute inset-y-0 left-0 pl-4 flex items-center text-slate-400 font-mono text-xl"
                        >$</span
                    >
                    <input
                        type="number"
                        id="target-amount"
                        name="amount"
                        placeholder="5,000.00"
                        step="100"
                        min="0"
                        required
                        class="w-full py-4 pl-12 pr-4 rounded-xl border-2 border-slate-200 focus:border-indigo focus:ring-0 text-slate-dark font-mono text-2xl font-bold bg-white transition-colors placeholder-slate-300"
                    />
                </div>
            </div>

            <div class="mb-5">
                <label
                    for="target-date"
                    class="block text-sm font-bold text-slate-500 uppercase tracking-wider mb-2"
                    >Target Date</label
                >
                <input
                    type="date"
                    id="target-date"
                    name="date"
                    required
                    class="w-full py-3 px-4 rounded-xl border-2 border-slate-200 focus:border-indigo focus:ring-0 text-slate-dark font-medium bg-white transition-colors"
                />
            </div>

            <div class="mb-8">
                <label
                    class="block text-sm font-bold text-slate-500 uppercase tracking-wider mb-3"
                    >Choose an Icon</label
                >
                <div class="grid grid-cols-4 gap-3">
                    <label class="cursor-pointer relative">
                        <input
                            type="radio"
                            name="icon"
                            value="flight"
                            checked
                            class="peer sr-only"
                        />
                        <div
                            class="w-full aspect-square rounded-2xl flex items-center justify-center bg-slate-50 text-slate-400 border-2 border-transparent peer-checked:border-indigo peer-checked:bg-indigo-bg peer-checked:text-indigo hover:bg-slate-100 transition-colors"
                        >
                            <span class="material-symbols-outlined text-3xl"
                                >flight</span
                            >
                        </div>
                    </label>
                    <label class="cursor-pointer relative">
                        <input
                            type="radio"
                            name="icon"
                            value="directions_car"
                            class="peer sr-only"
                        />
                        <div
                            class="w-full aspect-square rounded-2xl flex items-center justify-center bg-slate-50 text-slate-400 border-2 border-transparent peer-checked:border-orange peer-checked:bg-orange-bg peer-checked:text-orange hover:bg-slate-100 transition-colors"
                        >
                            <span class="material-symbols-outlined text-3xl"
                                >directions_car</span
                            >
                        </div>
                    </label>
                    <label class="cursor-pointer relative">
                        <input
                            type="radio"
                            name="icon"
                            value="home"
                            class="peer sr-only"
                        />
                        <div
                            class="w-full aspect-square rounded-2xl flex items-center justify-center bg-slate-50 text-slate-400 border-2 border-transparent peer-checked:border-teal peer-checked:bg-teal/10 peer-checked:text-teal hover:bg-slate-100 transition-colors"
                        >
                            <span class="material-symbols-outlined text-3xl"
                                >home</span
                            >
                        </div>
                    </label>
                    <label class="cursor-pointer relative">
                        <input
                            type="radio"
                            name="icon"
                            value="laptop_mac"
                            class="peer sr-only"
                        />
                        <div
                            class="w-full aspect-square rounded-2xl flex items-center justify-center bg-slate-50 text-slate-400 border-2 border-transparent peer-checked:border-pink-500 peer-checked:bg-pink-100 peer-checked:text-pink-600 hover:bg-slate-100 transition-colors"
                        >
                            <span class="material-symbols-outlined text-3xl"
                                >laptop_mac</span
                            >
                        </div>
                    </label>
                </div>
            </div>

            <div class="mb-8">
                <label
                    for="goal-notes"
                    class="block text-sm font-bold text-slate-500 uppercase tracking-wider mb-2"
                    >Notes / Details</label
                >
                <textarea
                    id="goal-notes"
                    name="notes"
                    rows="3"
                    placeholder="Add any extra details about this goal..."
                    class="w-full py-3 px-4 rounded-xl border-2 border-slate-200 focus:border-indigo focus:ring-0 text-slate-dark font-medium bg-white transition-colors placeholder-slate-300 resize-none"
                ></textarea>
            </div>

            <button
                type="submit"
                id="submit-goal-btn"
                class="w-full py-4 rounded-xl text-white font-bold text-lg bg-indigo hover:opacity-90 transition-opacity shadow-tactile hover:shadow-tactile-hover translate-y-0 hover:translate-y-[1px]"
            >
                Create Goal
            </button>
            <button
                type="button"
                id="delete-goal-btn"
                class="w-full mt-3 py-3 rounded-xl text-red-600 font-bold text-sm bg-red-50 hover:bg-red-100 transition-colors hidden"
            >
                Delete Goal
            </button>
        </form>
    </div>
</dialog>

<script>
    import {
        addGoal,
        getGoals,
        updateGoal,
        deleteGoal,
        isUserAdmin,
    } from "../../utils/store";

    function initGoalModal() {
        const modal = document.getElementById(
            "goal-modal",
        ) as HTMLDialogElement;
        const form = document.getElementById("goal-form") as HTMLFormElement;
        const closeBtn = document.getElementById("close-goal-modal");
        const targetDateInput = document.getElementById(
            "target-date",
        ) as HTMLInputElement;
        if (!modal || !form || !closeBtn) return;

        const goalIdInput = document.getElementById(
            "goal-id",
        ) as HTMLInputElement;
        const submitBtn = document.getElementById("submit-goal-btn");
        const deleteBtn = document.getElementById("delete-goal-btn");
        const titleEl = modal.querySelector("h2");
        const goalNameInput = document.getElementById(
            "goal-name",
        ) as HTMLInputElement;
        const targetAmountInput = document.getElementById(
            "target-amount",
        ) as HTMLInputElement;
        const goalNotesInput = document.getElementById(
            "goal-notes",
        ) as HTMLTextAreaElement;

        // Set default date to +6 months if empty
        if (targetDateInput && !targetDateInput.value) {
            const d = new Date();
            d.setMonth(d.getMonth() + 6);
            targetDateInput.valueAsDate = d;
        }

        (window as any).openGoalModal = async (goalId?: string) => {
            const isAdmin = await isUserAdmin();
            if (submitBtn)
                (submitBtn as HTMLElement).style.display = isAdmin
                    ? "block"
                    : "none";
            if (deleteBtn)
                (deleteBtn as HTMLElement).style.display = isAdmin
                    ? "block"
                    : "none";

            if (goalId) {
                const goals = await getGoals();
                const goal = goals.find((g: any) => g.id === goalId);
                if (goal) {
                    if (goalIdInput) goalIdInput.value = goal.id;
                    if (goalNameInput) goalNameInput.value = goal.name;
                    if (targetAmountInput)
                        targetAmountInput.value = goal.amount.toString();
                    if (targetDateInput) targetDateInput.value = goal.date;
                    if (goalNotesInput) goalNotesInput.value = goal.notes || "";

                    const iconInput = form.querySelector(
                        `input[name="icon"][value="${goal.icon}"]`,
                    ) as HTMLInputElement;
                    if (iconInput) iconInput.checked = true;

                    if (submitBtn) submitBtn.textContent = "Save Changes";
                    if (titleEl) titleEl.textContent = "Edit Savings Goal";
                    if (isAdmin) deleteBtn?.classList.remove("hidden");
                }
            } else {
                form.reset();
                if (goalIdInput) goalIdInput.value = "";
                if (submitBtn) submitBtn.textContent = "Create Goal";
                if (titleEl) titleEl.textContent = "New Savings Goal";
                deleteBtn?.classList.add("hidden");

                // Set default date to +6 months
                if (targetDateInput) {
                    const d = new Date();
                    d.setMonth(d.getMonth() + 6);
                    targetDateInput.valueAsDate = d;
                }
            }
            modal.showModal();
        };

        closeBtn.addEventListener("click", () => {
            modal.close();
            form.reset();
        });

        // Close on backdrop click
        modal.addEventListener("click", (e) => {
            const rect = modal.getBoundingClientRect();
            const isInDialog =
                rect.top <= e.clientY &&
                e.clientY <= rect.top + rect.height &&
                rect.left <= e.clientX &&
                e.clientX <= rect.left + rect.width;
            if (!isInDialog) {
                modal.close();
                form.reset();
            }
        });

        deleteBtn?.addEventListener("click", async () => {
            const id = goalIdInput.value;
            if (id && confirm("Are you sure you want to delete this goal?")) {
                await deleteGoal(id);
                modal.close();
                form.reset();
            }
        });

        form.addEventListener("submit", async (e) => {
            e.preventDefault();

            const btn = submitBtn as HTMLButtonElement;
            if (btn) {
                const originalText = btn.textContent;
                btn.disabled = true;
                btn.innerHTML =
                    '<span class="animate-spin material-symbols-outlined">progress_activity</span> Saving...';

                try {
                    const formData = new FormData(form);
                    const id = goalIdInput.value;

                    const goalData = {
                        name: formData.get("name") as string,
                        amount: parseFloat(formData.get("amount") as string),
                        date: formData.get("date") as string,
                        icon:
                            (
                                form.querySelector(
                                    'input[name="icon"]:checked',
                                ) as HTMLInputElement
                            )?.value || "savings",
                        notes: (formData.get("notes") as string) || "",
                    };

                    if (id) {
                        await updateGoal(id, goalData);
                    } else {
                        await addGoal(goalData);
                    }

                    modal.close();
                    form.reset();
                } catch (error) {
                    console.error("Error saving goal:", error);
                    alert("Error saving goal. Please try again.");
                } finally {
                    if (btn) {
                        btn.disabled = false;
                        btn.textContent = originalText;
                    }
                }
            }
        });
    }

    document.addEventListener("astro:page-load", initGoalModal);
</script>

<style>
    :global(body:has(dialog[open])) {
        overflow: hidden;
    }
</style>
