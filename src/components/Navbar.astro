---
const pathname = new URL(Astro.request.url).pathname;
const currentPath = pathname === "/" ? "/" : pathname.replace(/\/$/, "");
import ThemeToggle from "./ThemeToggle.astro";
---

<nav
    class="w-full px-6 py-4 lg:px-12 bg-white sticky top-0 z-50 border-b-4 border-slate-200"
>
    <div
        class="max-w-6xl mx-auto flex flex-col md:flex-row md:justify-between md:items-center"
    >
        <div class="flex items-center justify-between w-full md:w-auto">
            <div class="flex items-center gap-12">
                <div
                    class="w-12 h-12 bg-indigo text-white flex items-center justify-center font-mono font-bold text-2xl rounded-xl shadow-tactile"
                >
                    V
                </div>
                <!-- Desktop Nav -->
                <div class="hidden md:flex gap-8">
                    <a
                        href="/"
                        class={`nav-link font-sans text-base font-bold pb-1 border-b-4 transition-colors ${currentPath === "/" ? "text-indigo border-indigo" : "text-slate-400 hover:text-indigo border-transparent"}`}
                        >Dashboard</a
                    >
                    <a
                        href="/history"
                        class={`nav-link font-sans text-base font-bold pb-1 border-b-4 transition-colors ${currentPath === "/history" ? "text-indigo border-indigo" : "text-slate-400 hover:text-indigo border-transparent"}`}
                        >History</a
                    >
                    <a
                        href="/goals"
                        class={`nav-link font-sans text-base font-bold pb-1 border-b-4 transition-colors ${currentPath === "/goals" ? "text-indigo border-indigo" : "text-slate-400 hover:text-indigo border-transparent"}`}
                        >Goals &amp; Budgets</a
                    >
                </div>
            </div>
            <div class="flex items-center gap-4 md:hidden">
                <ThemeToggle />
                <div
                    class="bg-slate-100 rounded-full p-1 pr-4 flex items-center gap-3 border border-slate-200"
                >
                    <img
                        alt="User"
                        class="w-8 h-8 rounded-full object-cover border-2 border-white"
                        src="https://lh3.googleusercontent.com/aida-public/AB6AXuA95F-Jn7rj7RaszPbcQNIva-1w7s9xhXoia9MC5kswawawrH4zKRiCjTz_81qJ9hyAPA5C-6ZwRnrGMUYektWeirFee6L-mEtQ5PcDDA0pqU95Zm88Wmpux6DIarB4-b_d4B9cgp5B-tMo6-4euo1WaZdrB6BFCrH1F_RyWI83YTTSizAk-WX9rZprkffefxG5NbyK6dQiXmiMGHpuBGh9_IWjQaYLHNFLRm5e3O5FAdpWGaigcb5JLjH9Ihxb6f5utdB7quGJiUI"
                    />
                </div>
            </div>
        </div>

        <div class="hidden md:flex items-center gap-4">
            <ThemeToggle />
            <div
                class="bg-slate-100 rounded-full p-1 pr-4 flex items-center gap-3 border border-slate-200"
            >
                <img
                    alt="User"
                    class="w-8 h-8 rounded-full object-cover border-2 border-white"
                    src="https://lh3.googleusercontent.com/aida-public/AB6AXuA95F-Jn7rj7RaszPbcQNIva-1w7s9xhXoia9MC5kswawawrH4zKRiCjTz_81qJ9hyAPA5C-6ZwRnrGMUYektWeirFee6L-mEtQ5PcDDA0pqU95Zm88Wmpux6DIarB4-b_d4B9cgp5B-tMo6-4euo1WaZdrB6BFCrH1F_RyWI83YTTSizAk-WX9rZprkffefxG5NbyK6dQiXmiMGHpuBGh9_IWjQaYLHNFLRm5e3O5FAdpWGaigcb5JLjH9Ihxb6f5utdB7quGJiUI"
                />
                <span class="font-bold text-sm text-slate-dark">David G.</span>
                <button
                    id="reset-app-btn"
                    title="Reset All Data"
                    class="ml-2 text-slate-300 hover:text-red-500 transition-colors"
                >
                    <span class="material-symbols-outlined text-sm"
                        >restart_alt</span
                    >
                </button>
            </div>
        </div>

        <!-- Mobile Nav -->
        <div
            class="md:hidden flex gap-6 mt-4 overflow-x-auto pb-2 scrollbar-hide"
        >
            <a
                href="/"
                class={`nav-link whitespace-nowrap font-sans text-sm font-bold pb-1 border-b-2 transition-colors ${currentPath === "/" ? "text-indigo border-indigo" : "text-slate-400 hover:text-indigo border-transparent"}`}
                >Dashboard</a
            >
            <a
                href="/history"
                class={`nav-link whitespace-nowrap font-sans text-sm font-bold pb-1 border-b-2 transition-colors ${currentPath === "/history" ? "text-indigo border-indigo" : "text-slate-400 hover:text-indigo border-transparent"}`}
                >History</a
            >
            <a
                href="/goals"
                class={`nav-link whitespace-nowrap font-sans text-sm font-bold pb-1 border-b-2 transition-colors ${currentPath === "/goals" ? "text-indigo border-indigo" : "text-slate-400 hover:text-indigo border-transparent"}`}
                >Goals &amp; Budgets</a
            >
        </div>
    </div>
</nav>

<script>
    import { resetAllData } from "../utils/store";

    function initNavbar() {
        const resetBtn = document.getElementById("reset-app-btn");
        resetBtn?.addEventListener("click", () => {
            if (
                confirm(
                    "DANGER: This will delete ALL transactions, goals, and budgets. This action cannot be undone. Are you sure?",
                )
            ) {
                resetAllData();
                window.location.href = "/";
            }
        });
    }

    document.addEventListener("astro:page-load", initNavbar);
</script>
