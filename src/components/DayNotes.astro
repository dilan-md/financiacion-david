---
---

<div id="day-notes-display" class="hidden animate-fade-in mb-12">
    <div class="bg-white dark:bg-[#111111] rounded-3xl p-8 shadow-card border border-slate-100 dark:border-[#222222] transition-colors overflow-hidden">
        <div class="flex justify-between items-center mb-6">
            <div class="flex items-center gap-3">
                <div class="w-12 h-12 rounded-2xl bg-indigo/10 flex items-center justify-center text-indigo">
                    <span class="material-symbols-outlined">event_note</span>
                </div>
                <div>
                    <h3 id="notes-date-label" class="text-xl font-bold text-slate-dark dark:text-white">Day Notes</h3>
                    <p class="text-sm text-slate-400">Manage your activities and reminders</p>
                </div>
            </div>
            <button id="notes-close-btn" class="p-2 hover:bg-slate-100 dark:hover:bg-slate-800 rounded-xl text-slate-400 transition-colors">
                <span class="material-symbols-outlined">close</span>
            </button>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
            <!-- Left Side: Existing Notes -->
            <div class="space-y-4">
                <h4 class="text-xs font-bold text-slate-400 uppercase tracking-widest px-1">Planned Activities</h4>
                <div id="notes-content-list" class="space-y-3 min-h-[100px]">
                    <!-- Notes injected here -->
                </div>
            </div>

            <!-- Right Side: Add New Note -->
            <div class="space-y-4">
                <h4 class="text-xs font-bold text-slate-400 uppercase tracking-widest px-1">Add Note</h4>
                <div class="bg-slate-50 dark:bg-[#0a0a0a] p-6 rounded-2xl border border-dashed border-slate-200 dark:border-slate-800">
                    <textarea 
                        id="note-text-area" 
                        placeholder="What's on your mind for this day?"
                        class="w-full bg-transparent border-none outline-none text-slate-700 dark:text-slate-300 placeholder:text-slate-400 resize-none min-h-[80px]"
                    ></textarea>
                    <div class="flex justify-end mt-4">
                        <button id="save-note-btn" class="bg-indigo text-white px-6 py-2 rounded-xl font-bold shadow-sm hover:opacity-90 transition-all flex items-center gap-2">
                            <span>Save Note</span>
                            <span class="material-symbols-outlined text-sm">send</span>
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    import { getCalendarNotes, addCalendarNote, deleteCalendarNote, getGoals, formatCurrency } from "../utils/store";

    let selectedDateKey = '';

    function initDayNotes() {
        const container = document.getElementById('day-notes-display');
        const dateLabel = document.getElementById('notes-date-label');
        const notesList = document.getElementById('notes-content-list');
        const closeBtn = document.getElementById('notes-close-btn');
        const saveBtn = document.getElementById('save-note-btn');
        const textArea = document.getElementById('note-text-area') as HTMLTextAreaElement;

        if (!container) return;

        window.addEventListener('calendar-date-selected', async (e: any) => {
            const { date, displayDate } = e.detail;
            selectedDateKey = date;
            
            if (dateLabel) dateLabel.textContent = `Notes for ${displayDate}`;
            container.classList.remove('hidden');
            container.scrollIntoView({ behavior: 'smooth', block: 'center' });
            
            await refreshNotes();
        });

        async function refreshNotes() {
            if (!selectedDateKey || !notesList) return;
            
            const [allNotes, allGoals] = await Promise.all([
                getCalendarNotes(),
                getGoals()
            ]);

            const dayNotes = allNotes.filter(n => n.date === selectedDateKey);
            const dayGoals = allGoals.filter(g => g.date === selectedDateKey);
            
            let html = '';

            // Render Goals first
            if (dayGoals.length > 0) {
                html += `
                    <div class="mb-6 space-y-3">
                        <h5 class="text-[10px] font-bold text-orange uppercase tracking-widest px-1">Goal Deadlines</h5>
                        ${dayGoals.map(g => `
                            <div class="flex items-center gap-4 bg-orange/5 p-4 rounded-2xl border border-orange/10 transition-all border-l-4 border-l-orange">
                                <div class="w-10 h-10 rounded-xl bg-orange/10 flex items-center justify-center text-orange shrink-0">
                                    <span class="material-symbols-outlined">flag</span>
                                </div>
                                <div class="flex-1 min-w-0">
                                    <h4 class="font-bold text-slate-dark dark:text-white truncate">${g.name}</h4>
                                    <p class="text-xs text-slate-500 font-medium font-mono">Target: ${formatCurrency(g.amount)}</p>
                                </div>
                                <a href="/goals" class="text-orange text-xs font-bold hover:underline shrink-0">View Goal</a>
                            </div>
                        `).join('')}
                    </div>
                    <div class="h-px bg-slate-100 dark:bg-slate-800 my-6"></div>
                `;
            }

            // Render Notes
            if (dayNotes.length === 0 && dayGoals.length === 0) {
                html += `
                    <div class="py-8 text-center bg-slate-50 dark:bg-[#0a0a0a] rounded-2xl border border-slate-100 dark:border-slate-800">
                        <span class="material-symbols-outlined text-slate-200 dark:text-slate-800 text-4xl mb-2">sticky_note_2</span>
                        <p class="text-sm text-slate-400">No activities found for this day</p>
                    </div>
                `;
            } else {
                html += dayNotes.map(n => `
                    <div class="group flex justify-between items-start gap-4 bg-white dark:bg-[#111111] p-4 rounded-2xl border border-slate-100 dark:border-slate-800 transition-all hover:shadow-sm">
                        <p class="text-sm text-slate-600 dark:text-slate-400 leading-relaxed">${n.note}</p>
                        <button class="delete-day-note p-1 text-slate-300 hover:text-red-500 opacity-0 group-hover:opacity-100 transition-all" data-id="${n.id}">
                            <span class="material-symbols-outlined text-sm">delete</span>
                        </button>
                    </div>
                `).join('');
            }

            notesList.innerHTML = html;

            notesList.querySelectorAll('.delete-day-note').forEach(btn => {
                btn.addEventListener('click', async () => {
                    const id = (btn as HTMLElement).dataset.id!;
                    await deleteCalendarNote(id);
                    await refreshNotes();
                });
            });
        }

        saveBtn?.addEventListener('click', async () => {
            if (!selectedDateKey || !textArea.value.trim()) return;
            
            await addCalendarNote(selectedDateKey, textArea.value.trim());
            textArea.value = '';
            await refreshNotes();
        });

        closeBtn?.addEventListener('click', () => {
            container.classList.add('hidden');
            selectedDateKey = '';
        });

        window.addEventListener('calendar-notes-updated', refreshNotes);
    }

    document.addEventListener('astro:page-load', initDayNotes);
</script>

<style>
    .animate-fade-in {
        animation: fadeIn 0.4s cubic-bezier(0.16, 1, 0.3, 1);
    }
    @keyframes fadeIn {
        from { opacity: 0; transform: translateY(20px); }
        to { opacity: 1; transform: translateY(0); }
    }
</style>
