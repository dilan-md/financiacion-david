---
import Layout from "../layouts/Layout.astro";
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";
import BalanceCard from "../components/BalanceCard.astro";
---

<Layout title="Dashboard - Vibrant Ledger">
    <Navbar />
    <main class="flex-1 px-6 py-8 lg:px-12 max-w-6xl mx-auto w-full relative">
        <div class="animate-fade-in">
            <div class="grid grid-cols-1 md:grid-cols-3 gap-8 mb-12">
                <BalanceCard />
                <div class="flex flex-col gap-4 justify-center">
                    <button
                        class="group flex-1 bg-white border-2 border-indigo text-indigo hover:bg-indigo hover:text-white rounded-2xl p-6 transition-all shadow-tactile hover:shadow-tactile-hover translate-y-0 hover:translate-y-0.5 flex items-center justify-between"
                    >
                        <div class="text-left">
                            <span class="block font-bold text-lg"
                                >Add Income</span
                            >
                            <span
                                class="text-sm opacity-70 group-hover:text-indigo-100"
                                >Paycheck, Freelance, etc.</span
                            >
                        </div>
                        <div
                            class="w-12 h-12 rounded-full bg-indigo/10 group-hover:bg-white/20 flex items-center justify-center"
                        >
                            <span class="material-symbols-outlined text-2xl"
                                >arrow_downward</span
                            >
                        </div>
                    </button>
                    <button
                        class="group flex-1 bg-white border-2 border-orange text-orange hover:bg-orange hover:text-white rounded-2xl p-6 transition-all shadow-tactile hover:shadow-tactile-hover translate-y-0 hover:translate-y-0.5 flex items-center justify-between"
                    >
                        <div class="text-left">
                            <span class="block font-bold text-lg"
                                >Add Expense</span
                            >
                            <span
                                class="text-sm opacity-70 group-hover:text-orange-100"
                                >Food, Bills, Shopping</span
                            >
                        </div>
                        <div
                            class="w-12 h-12 rounded-full bg-orange/10 group-hover:bg-white/20 flex items-center justify-center"
                        >
                            <span class="material-symbols-outlined text-2xl"
                                >arrow_upward</span
                            >
                        </div>
                    </button>
                </div>
            </div>
            <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
                <div class="lg:col-span-2 space-y-8">
                    <section
                        class="bg-white rounded-3xl p-8 shadow-card border border-slate-100"
                    >
                        <div class="flex justify-between items-center mb-8">
                            <h2
                                class="text-2xl font-bold text-slate-dark flex items-center gap-3"
                            >
                                <span class="w-2 h-8 bg-orange rounded-full"
                                ></span>
                                Savings Goal
                            </h2>
                            <button
                                class="text-slate-400 hover:text-indigo transition-colors"
                            >
                                <span class="material-symbols-outlined"
                                    >more_horiz</span
                                >
                            </button>
                        </div>
                        <div
                            class="flex flex-col md:flex-row items-center gap-10"
                        >
                            <div class="relative w-40 h-40 flex-shrink-0">
                                <svg
                                    class="w-full h-full"
                                    viewBox="0 0 100 100"
                                >
                                    <circle
                                        class="text-slate-100 stroke-current"
                                        cx="50"
                                        cy="50"
                                        fill="transparent"
                                        r="40"
                                        stroke-width="12"></circle>
                                    <circle
                                        class="text-indigo progress-ring-circle stroke-current"
                                        cx="50"
                                        cy="50"
                                        fill="transparent"
                                        r="40"
                                        stroke-dasharray="251.2"
                                        stroke-dashoffset="62.8"
                                        stroke-linecap="round"
                                        stroke-width="12"></circle>
                                </svg>
                                <div
                                    class="absolute inset-0 flex items-center justify-center flex-col"
                                >
                                    <span
                                        class="font-mono text-3xl font-bold text-indigo"
                                        >75%</span
                                    >
                                </div>
                            </div>
                            <div class="flex-1 w-full">
                                <div
                                    class="flex justify-between items-end mb-2"
                                >
                                    <div>
                                        <h3
                                            class="text-xl font-bold text-slate-dark mb-1"
                                        >
                                            New Car Fund
                                        </h3>
                                        <p class="text-slate-500 font-medium">
                                            Target: Dec 2024
                                        </p>
                                    </div>
                                    <div
                                        class="w-12 h-12 bg-indigo/10 rounded-xl flex items-center justify-center text-indigo"
                                    >
                                        <span class="material-symbols-outlined"
                                            >directions_car</span
                                        >
                                    </div>
                                </div>
                                <div class="grid grid-cols-2 gap-4 mt-6">
                                    <div
                                        class="bg-slate-50 p-4 rounded-xl border border-slate-100"
                                    >
                                        <span
                                            class="text-xs font-bold text-slate-400 uppercase tracking-wider"
                                            >Saved</span
                                        >
                                        <p
                                            class="font-mono text-xl font-bold text-slate-dark mt-1"
                                        >
                                            $15,000
                                        </p>
                                    </div>
                                    <div
                                        class="bg-slate-50 p-4 rounded-xl border border-slate-100"
                                    >
                                        <span
                                            class="text-xs font-bold text-slate-400 uppercase tracking-wider"
                                            >Remaining</span
                                        >
                                        <p
                                            class="font-mono text-xl font-bold text-slate-400 mt-1"
                                        >
                                            $5,000
                                        </p>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </section>
                    <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
                        <section
                            class="bg-white rounded-3xl p-6 shadow-card border border-slate-100 flex items-center gap-4"
                        >
                            <div class="relative w-20 h-20 flex-shrink-0">
                                <svg
                                    class="w-full h-full"
                                    viewBox="0 0 100 100"
                                >
                                    <circle
                                        class="text-slate-100 stroke-current"
                                        cx="50"
                                        cy="50"
                                        fill="transparent"
                                        r="40"
                                        stroke-width="10"></circle>
                                    <circle
                                        class="text-orange progress-ring-circle stroke-current"
                                        cx="50"
                                        cy="50"
                                        fill="transparent"
                                        r="40"
                                        stroke-dasharray="251.2"
                                        stroke-dashoffset="100"
                                        stroke-linecap="round"
                                        stroke-width="10"></circle>
                                </svg>
                                <div
                                    class="absolute inset-0 flex items-center justify-center"
                                >
                                    <span
                                        class="material-symbols-outlined text-orange"
                                        >restaurant</span
                                    >
                                </div>
                            </div>
                            <div>
                                <p
                                    class="text-slate-400 text-sm font-bold uppercase"
                                >
                                    Dining
                                </p>
                                <p
                                    class="font-mono text-xl font-bold text-slate-dark"
                                >
                                    $450.00
                                </p>
                            </div>
                        </section>
                        <section
                            class="bg-white rounded-3xl p-6 shadow-card border border-slate-100 flex items-center gap-4"
                        >
                            <div class="relative w-20 h-20 flex-shrink-0">
                                <svg
                                    class="w-full h-full"
                                    viewBox="0 0 100 100"
                                >
                                    <circle
                                        class="text-slate-100 stroke-current"
                                        cx="50"
                                        cy="50"
                                        fill="transparent"
                                        r="40"
                                        stroke-width="10"></circle>
                                    <circle
                                        class="text-indigo progress-ring-circle stroke-current"
                                        cx="50"
                                        cy="50"
                                        fill="transparent"
                                        r="40"
                                        stroke-dasharray="251.2"
                                        stroke-dashoffset="40"
                                        stroke-linecap="round"
                                        stroke-width="10"></circle>
                                </svg>
                                <div
                                    class="absolute inset-0 flex items-center justify-center"
                                >
                                    <span
                                        class="material-symbols-outlined text-indigo"
                                        >shopping_bag</span
                                    >
                                </div>
                            </div>
                            <div>
                                <p
                                    class="text-slate-400 text-sm font-bold uppercase"
                                >
                                    Shopping
                                </p>
                                <p
                                    class="font-mono text-xl font-bold text-slate-dark"
                                >
                                    $820.00
                                </p>
                            </div>
                        </section>
                    </div>
                </div>
                <div class="lg:col-span-1">
                    <section
                        class="bg-white rounded-3xl p-8 h-full min-h-[500px] shadow-card border border-slate-100 relative"
                    >
                        <div class="flex justify-between items-center mb-6">
                            <h2 class="text-2xl font-bold text-slate-dark">
                                Recent
                            </h2>
                            <a
                                class="text-indigo font-bold text-sm hover:underline"
                                href="#">View All</a
                            >
                        </div>
                        <div class="space-y-4">
                            <div
                                class="flex items-center justify-between p-3 hover:bg-slate-50 rounded-xl transition-colors cursor-pointer group"
                            >
                                <div class="flex items-center gap-4">
                                    <div
                                        class="w-12 h-12 bg-orange/10 text-orange rounded-xl flex items-center justify-center group-hover:scale-110 transition-transform"
                                    >
                                        <span class="material-symbols-outlined"
                                            >shopping_cart</span
                                        >
                                    </div>
                                    <div>
                                        <p
                                            class="font-bold text-slate-dark text-base"
                                        >
                                            Whole Foods
                                        </p>
                                        <span
                                            class="inline-block px-2 py-0.5 rounded-md bg-orange text-white text-[10px] font-bold uppercase tracking-wider mt-1"
                                            >Groceries</span
                                        >
                                    </div>
                                </div>
                                <span
                                    class="font-mono text-base font-bold text-slate-dark"
                                    >-$124.50</span
                                >
                            </div>
                            <div
                                class="flex items-center justify-between p-3 hover:bg-slate-50 rounded-xl transition-colors cursor-pointer group"
                            >
                                <div class="flex items-center gap-4">
                                    <div
                                        class="w-12 h-12 bg-indigo/10 text-indigo rounded-xl flex items-center justify-center group-hover:scale-110 transition-transform"
                                    >
                                        <span class="material-symbols-outlined"
                                            >work</span
                                        >
                                    </div>
                                    <div>
                                        <p
                                            class="font-bold text-slate-dark text-base"
                                        >
                                            Design Project
                                        </p>
                                        <span
                                            class="inline-block px-2 py-0.5 rounded-md bg-indigo text-white text-[10px] font-bold uppercase tracking-wider mt-1"
                                            >Income</span
                                        >
                                    </div>
                                </div>
                                <span
                                    class="font-mono text-base font-bold text-indigo"
                                    >+$1,500.00</span
                                >
                            </div>
                            <div
                                class="flex items-center justify-between p-3 hover:bg-slate-50 rounded-xl transition-colors cursor-pointer group"
                            >
                                <div class="flex items-center gap-4">
                                    <div
                                        class="w-12 h-12 bg-pink-100 text-pink-600 rounded-xl flex items-center justify-center group-hover:scale-110 transition-transform"
                                    >
                                        <span class="material-symbols-outlined"
                                            >restaurant</span
                                        >
                                    </div>
                                    <div>
                                        <p
                                            class="font-bold text-slate-dark text-base"
                                        >
                                            Bistrot Leo
                                        </p>
                                        <span
                                            class="inline-block px-2 py-0.5 rounded-md bg-pink-500 text-white text-[10px] font-bold uppercase tracking-wider mt-1"
                                            >Dining</span
                                        >
                                    </div>
                                </div>
                                <span
                                    class="font-mono text-base font-bold text-slate-dark"
                                    >-$85.00</span
                                >
                            </div>
                            <div
                                class="flex items-center justify-between p-3 hover:bg-slate-50 rounded-xl transition-colors cursor-pointer group"
                            >
                                <div class="flex items-center gap-4">
                                    <div
                                        class="w-12 h-12 bg-yellow-100 text-yellow-600 rounded-xl flex items-center justify-center group-hover:scale-110 transition-transform"
                                    >
                                        <span class="material-symbols-outlined"
                                            >bolt</span
                                        >
                                    </div>
                                    <div>
                                        <p
                                            class="font-bold text-slate-dark text-base"
                                        >
                                            Electric Bill
                                        </p>
                                        <span
                                            class="inline-block px-2 py-0.5 rounded-md bg-yellow-500 text-white text-[10px] font-bold uppercase tracking-wider mt-1"
                                            >Utilities</span
                                        >
                                    </div>
                                </div>
                                <span
                                    class="font-mono text-base font-bold text-slate-dark"
                                    >-$145.20</span
                                >
                            </div>
                            <div
                                class="flex items-center justify-between p-3 hover:bg-slate-50 rounded-xl transition-colors cursor-pointer group"
                            >
                                <div class="flex items-center gap-4">
                                    <div
                                        class="w-12 h-12 bg-purple-100 text-purple-600 rounded-xl flex items-center justify-center group-hover:scale-110 transition-transform"
                                    >
                                        <span class="material-symbols-outlined"
                                            >movie</span
                                        >
                                    </div>
                                    <div>
                                        <p
                                            class="font-bold text-slate-dark text-base"
                                        >
                                            Cinema 4
                                        </p>
                                        <span
                                            class="inline-block px-2 py-0.5 rounded-md bg-purple-500 text-white text-[10px] font-bold uppercase tracking-wider mt-1"
                                            >Fun</span
                                        >
                                    </div>
                                </div>
                                <span
                                    class="font-mono text-base font-bold text-slate-dark"
                                    >-$32.00</span
                                >
                            </div>
                        </div>
                        <div class="mt-8 pt-6 border-t border-slate-100">
                            <button
                                class="w-full py-4 bg-slate-100 text-slate-dark font-bold rounded-xl hover:bg-indigo hover:text-white transition-colors"
                            >
                                Load More Activity
                            </button>
                        </div>
                    </section>
                </div>
            </div>
        </div>
    </main>
    <Footer />
</Layout>
