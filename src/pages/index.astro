---
import Layout from "../layouts/Layout.astro";
import Navbar from "../components/Navbar.astro";
import BalanceCard from "../components/BalanceCard.astro";
import TransactionModal from "../components/modals/TransactionModal.astro";
---

<Layout title="Dashboard - Vibrant Ledger">
    <Navbar />
    <main class="flex-1 px-6 py-8 lg:px-12 max-w-6xl mx-auto w-full relative">
        <div class="animate-fade-in">
            <div class="grid grid-cols-1 md:grid-cols-3 gap-8 mb-12">
                <BalanceCard />
                <div class="flex flex-col gap-4 justify-center">
                    <button
                        onclick="window.openTransactionModal('income')"
                        class="group flex-1 bg-white border-2 border-indigo text-indigo hover:bg-indigo hover:text-white rounded-2xl p-6 transition-all shadow-tactile hover:shadow-tactile-hover translate-y-0 hover:translate-y-0.5 flex items-center justify-between"
                    >
                        <div class="text-left">
                            <span class="block font-bold text-lg"
                                >Add Income</span
                            >
                            <span
                                class="text-sm opacity-70 group-hover:text-indigo-100"
                                >Paycheck, Freelance, etc.</span
                            >
                        </div>
                        <div
                            class="w-12 h-12 rounded-full bg-indigo/10 group-hover:bg-white/20 flex items-center justify-center"
                        >
                            <span class="material-symbols-outlined text-2xl"
                                >arrow_downward</span
                            >
                        </div>
                    </button>
                    <button
                        onclick="window.openTransactionModal('expense')"
                        class="group flex-1 bg-white border-2 border-orange text-orange hover:bg-orange hover:text-white rounded-2xl p-6 transition-all shadow-tactile hover:shadow-tactile-hover translate-y-0 hover:translate-y-0.5 flex items-center justify-between"
                    >
                        <div class="text-left">
                            <span class="block font-bold text-lg"
                                >Add Expense</span
                            >
                            <span
                                class="text-sm opacity-70 group-hover:text-orange-100"
                                >Food, Bills, Shopping</span
                            >
                        </div>
                        <div
                            class="w-12 h-12 rounded-full bg-orange/10 group-hover:bg-white/20 flex items-center justify-center"
                        >
                            <span class="material-symbols-outlined text-2xl"
                                >arrow_upward</span
                            >
                        </div>
                    </button>
                </div>
            </div>
            <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
                <!-- Left Column: Goals and Categories (2/3) -->
                <div class="lg:col-span-2 space-y-8">
                    <section
                        class="bg-white rounded-3xl p-8 shadow-card border border-slate-100"
                    >
                        <div class="flex justify-between items-center mb-8">
                            <h2
                                class="text-2xl font-bold text-slate-dark flex items-center gap-3"
                            >
                                <span class="w-2 h-8 bg-orange rounded-full"
                                ></span>
                                Savings Goal
                            </h2>
                            <a
                                href="/goals"
                                class="text-slate-400 hover:text-indigo transition-colors"
                            >
                                <span class="material-symbols-outlined"
                                    >more_horiz</span
                                >
                            </a>
                        </div>
                        <div id="goal-container">
                            <!-- Dynamic Goal Content -->
                            <div
                                class="flex flex-col md:flex-row items-center gap-10 opacity-50"
                            >
                                <p>Loading goals...</p>
                            </div>
                        </div>
                    </section>

                    <div
                        class="grid grid-cols-1 sm:grid-cols-2 gap-6"
                        id="dashboard-category-cards"
                    >
                        <!-- Dynamic Category Cards -->
                    </div>
                </div>

                <!-- Right Column: Recent Activity (1/3) -->
                <div class="lg:col-span-1">
                    <section
                        class="bg-white rounded-3xl p-8 h-full min-h-[500px] shadow-card border border-slate-100 relative"
                    >
                        <div class="flex justify-between items-center mb-6">
                            <h2 class="text-2xl font-bold text-slate-dark">
                                Recent
                            </h2>
                            <a
                                class="text-indigo font-bold text-sm hover:underline"
                                href="/history">View All</a
                            >
                        </div>
                        <div class="space-y-4" id="recent-activity-list">
                            <!-- Transactions will be injected here -->
                            <div class="py-12 text-center text-slate-400">
                                <span
                                    class="material-symbols-outlined text-4xl mb-2 block opacity-20"
                                    >history</span
                                >
                                <p class="text-sm font-medium">
                                    No recent activity
                                </p>
                            </div>
                        </div>
                        <div class="mt-8 pt-6 border-t border-slate-100">
                            <a
                                href="/history"
                                class="w-full py-4 bg-slate-100 text-slate-dark font-bold rounded-xl hover:bg-indigo hover:text-white transition-colors flex items-center justify-center"
                            >
                                View All Activity
                            </a>
                        </div>
                    </section>
                </div>
            </div>
        </div>
    </main>
    <TransactionModal />
</Layout>

<script>
    import {
        getTransactions,
        getGoals,
        getBudgets,
        formatCurrency,
        parseLocalDate,
        isUserAdmin,
    } from "../utils/store";

    async function renderDashboard() {
        const isAdmin = await isUserAdmin();
        const actionButtons = document.querySelectorAll(
            ".flex.flex-col.gap-4.justify-center button",
        );

        if (!isAdmin) {
            actionButtons.forEach(
                (btn) => ((btn as HTMLElement).style.display = "none"),
            );
        }

        const activityContainer = document.getElementById(
            "recent-activity-list",
        );
        const goalContainer = document.getElementById("goal-container");
        const categoryCards = document.getElementById(
            "dashboard-category-cards",
        );

        // Fetch data asynchronously
        const [transactions, goals, budgets] = await Promise.all([
            getTransactions(),
            getGoals(),
            getBudgets(),
        ]);

        // 1. Render Recent Activity
        if (activityContainer) {
            const recent = transactions.slice(0, 5);
            if (recent.length === 0) {
                activityContainer.innerHTML = `
                    <div class="py-12 text-center text-slate-400">
                        <span class="material-symbols-outlined text-4xl mb-2 block opacity-20">history</span>
                        <p class="text-sm font-medium">No recent activity</p>
                    </div>
                `;
            } else {
                const categoryIcons: Record<string, string> = {
                    food: "restaurant",
                    dining: "restaurant",
                    shopping: "shopping_cart",
                    transportation: "directions_car",
                    bills: "bolt",
                    entertainment: "movie",
                    salary: "work",
                    freelance: "laptop_mac",
                    investments: "show_chart",
                    other: "package",
                };

                activityContainer.innerHTML = recent
                    .map((t) => {
                        const category = t.category || "other";
                        const icon = categoryIcons[category] || "payments";
                        const isIncome = t.type === "income";
                        const iconStyle = isIncome
                            ? "bg-indigo/10 text-indigo"
                            : "bg-orange/10 text-orange";
                        const amountClass = isIncome
                            ? "text-indigo"
                            : "text-slate-dark";
                        const prefix = isIncome ? "+" : "-";

                        return `
                        <div 
                            onclick="window.openTransactionModal('${t.id}')"
                            class="flex items-center justify-between p-3 hover:bg-slate-50 rounded-xl transition-colors cursor-pointer group"
                        >
                            <div class="flex items-center gap-4">
                                <div class="w-12 h-12 ${iconStyle} rounded-xl flex items-center justify-center group-hover:scale-110 transition-transform">
                                    <span class="material-symbols-outlined">${icon}</span>
                                </div>
                                <div>
                                    <p class="font-bold text-slate-dark text-base">${t.note || category.charAt(0).toUpperCase() + category.slice(1)}</p>
                                    <span class="inline-block px-2 py-0.5 rounded-md bg-slate-100 text-[10px] font-bold uppercase tracking-wider mt-1">
                                        ${category.replace("_", " ")}
                                    </span>
                                </div>
                            </div>
                            <span class="font-mono text-base font-bold ${amountClass}">${prefix}${formatCurrency(t.amount)}</span>
                        </div>
                    `;
                    })
                    .join("");
            }
        }

        // 2. Render Goals Carousel
        if (goalContainer) {
            if (goals.length > 0) {
                // Initialize or clamp the index
                if ((window as any).__goalIndex === undefined) (window as any).__goalIndex = 0;
                let idx = (window as any).__goalIndex;
                if (idx >= goals.length) idx = 0;
                if (idx < 0) idx = goals.length - 1;
                (window as any).__goalIndex = idx;

                const g = goals[idx];
                const progress =
                    Math.min(100, Math.round((g.current / g.amount) * 100)) ||
                    0;
                const dashoffset = 251.2 - (251.2 * progress) / 100;
                const notesHtml = g.notes ? `<p class="text-slate-500 dark:text-slate-400 text-sm mt-2 italic">${g.notes}</p>` : '';

                const showArrows = goals.length > 1;

                goalContainer.innerHTML = `
                    <div class="relative">
                        ${showArrows ? `
                        <button id="goal-prev" class="absolute -left-3 top-1/2 -translate-y-1/2 z-10 w-10 h-10 rounded-full bg-white dark:bg-slate-800 border border-slate-200 dark:border-slate-700 shadow-md flex items-center justify-center text-slate-400 hover:text-indigo hover:border-indigo hover:shadow-lg hover:scale-110 active:scale-95 transition-all duration-200 cursor-pointer">
                            <span class="material-symbols-outlined text-xl">chevron_left</span>
                        </button>
                        <button id="goal-next" class="absolute -right-3 top-1/2 -translate-y-1/2 z-10 w-10 h-10 rounded-full bg-white dark:bg-slate-800 border border-slate-200 dark:border-slate-700 shadow-md flex items-center justify-center text-slate-400 hover:text-indigo hover:border-indigo hover:shadow-lg hover:scale-110 active:scale-95 transition-all duration-200 cursor-pointer">
                            <span class="material-symbols-outlined text-xl">chevron_right</span>
                        </button>
                        ` : ''}
                        <div class="goal-slide-in flex flex-col md:flex-row items-center gap-10 px-4">
                            <div class="relative w-40 h-40 flex-shrink-0">
                                <svg class="w-full h-full" viewBox="0 0 100 100">
                                    <circle class="text-slate-100 dark:text-slate-700 stroke-current" cx="50" cy="50" fill="transparent" r="40" stroke-width="12"></circle>
                                    <circle class="text-indigo stroke-current" cx="50" cy="50" fill="transparent" r="40" stroke-dasharray="251.2" stroke-dashoffset="${dashoffset}" stroke-linecap="round" stroke-width="12"></circle>
                                </svg>
                                <div class="absolute inset-0 flex items-center justify-center flex-col">
                                    <span class="font-mono text-3xl font-bold text-indigo">${progress}%</span>
                                </div>
                            </div>
                            <div class="flex-1 w-full">
                                <div class="flex justify-between items-end mb-2">
                                    <div>
                                        <h3 class="text-xl font-bold text-slate-dark dark:text-white mb-1">${g.name}</h3>
                                        <p class="text-slate-500 dark:text-slate-400 font-medium">Target: ${parseLocalDate(g.date).toLocaleDateString("default", { month: "short", year: "numeric" })}</p>
                                        ${notesHtml}
                                    </div>
                                    <div class="w-12 h-12 bg-indigo/10 rounded-xl flex items-center justify-center text-indigo">
                                        <span class="material-symbols-outlined">${g.icon}</span>
                                    </div>
                                </div>
                                <div class="grid grid-cols-2 gap-4 mt-6">
                                    <div class="bg-slate-50 dark:bg-slate-800 p-4 rounded-xl border border-slate-100 dark:border-slate-700">
                                        <span class="text-xs font-bold text-slate-400 uppercase tracking-wider">Saved</span>
                                        <p class="font-mono text-xl font-bold text-slate-dark dark:text-white mt-1">${formatCurrency(g.current)}</p>
                                    </div>
                                    <div class="bg-slate-50 dark:bg-slate-800 p-4 rounded-xl border border-slate-100 dark:border-slate-700">
                                        <span class="text-xs font-bold text-slate-400 uppercase tracking-wider">Remaining</span>
                                        <p class="font-mono text-xl font-bold text-slate-400 mt-1">${formatCurrency(Math.max(0, g.amount - g.current))}</p>
                                    </div>
                                </div>
                            </div>
                        </div>
                        ${showArrows ? `
                        <div class="flex items-center justify-center gap-2 mt-6">
                            ${goals.map((_: any, i: number) => `
                                <div class="w-2 h-2 rounded-full transition-all duration-300 ${i === idx ? 'bg-indigo w-6' : 'bg-slate-300 dark:bg-slate-600'}"></div>
                            `).join('')}
                        </div>
                        ` : ''}
                    </div>
                `;

                // Wire arrow events
                if (showArrows) {
                    document.getElementById('goal-prev')?.addEventListener('click', () => {
                        (window as any).__goalIndex = ((window as any).__goalIndex - 1 + goals.length) % goals.length;
                        renderDashboard();
                    });
                    document.getElementById('goal-next')?.addEventListener('click', () => {
                        (window as any).__goalIndex = ((window as any).__goalIndex + 1) % goals.length;
                        renderDashboard();
                    });
                }
            } else {
                goalContainer.innerHTML = `
                    <div class="py-10 text-center text-slate-400 border-2 border-dashed border-slate-100 dark:border-slate-700 rounded-2xl">
                        <p>No active goals. Add one in the Goals page!</p>
                        <a href="/goals" class="text-indigo font-bold mt-2 inline-block">Go to Goals</a>
                    </div>
                `;
            }
        }

        // 3. Render Category Cards
        if (categoryCards) {
            const spendingByCategory: Record<string, number> = {};
            transactions.forEach((t) => {
                if (t.type === "expense")
                    spendingByCategory[t.category] =
                        (spendingByCategory[t.category] || 0) + t.amount;
            });

            // If no budgets/transactions, show placeholders
            const topCategories = ["dining", "shopping"];
            categoryCards.innerHTML = topCategories
                .map((cat) => {
                    const limit = budgets[cat] || 0;
                    const spent = spendingByCategory[cat] || 0;
                    const progress =
                        limit > 0
                            ? Math.min(100, Math.round((spent / limit) * 100))
                            : 0;
                    const dashoffset = 251.2 - (251.2 * progress) / 100;
                    const icon =
                        cat === "dining" ? "restaurant" : "shopping_bag";
                    const color =
                        cat === "dining" ? "text-orange" : "text-indigo";
                    const strokeColor =
                        cat === "dining" ? "text-orange" : "text-indigo";

                    return `
                    <section class="bg-white rounded-3xl p-6 shadow-card border border-slate-100 flex items-center gap-4">
                        <div class="relative w-20 h-20 flex-shrink-0">
                            <svg class="w-full h-full" viewBox="0 0 100 100">
                                <circle class="text-slate-100 stroke-current" cx="50" cy="50" fill="transparent" r="40" stroke-width="10"></circle>
                                <circle class="${strokeColor} stroke-current" cx="50" cy="50" fill="transparent" r="40" stroke-dasharray="251.2" stroke-dashoffset="${dashoffset}" stroke-linecap="round" stroke-width="10"></circle>
                            </svg>
                            <div class="absolute inset-0 flex items-center justify-center">
                                <span class="material-symbols-outlined ${color}">${icon}</span>
                            </div>
                        </div>
                        <div>
                            <p class="text-slate-400 text-sm font-bold uppercase">${cat}</p>
                            <p class="font-mono text-xl font-bold text-slate-dark">${formatCurrency(spent)}</p>
                        </div>
                    </section>
                `;
                })
                .join("");
        }
    }

    document.addEventListener("astro:page-load", () => {
        renderDashboard();
    });

    // Ensure we only listen once and it still works after navigation
    if (!(window as any).hasTransactionsListener) {
        window.addEventListener("transactions-updated", () => {
            renderDashboard();
        });
        window.addEventListener("goals-updated", () => {
            renderDashboard();
        });
        window.addEventListener("budgets-updated", () => {
            renderDashboard();
        });
        (window as any).hasTransactionsListener = true;
    }
</script>
