---
import Layout from "../layouts/Layout.astro";
import Navbar from "../components/Navbar.astro";
import GoalModal from "../components/modals/GoalModal.astro";
import BudgetModal from "../components/modals/BudgetModal.astro";
import AddFundsModal from "../components/modals/AddFundsModal.astro";
---

<Layout title="Goals & Budgets - Vibrant Ledger">
    <Navbar />
    <main class="flex-1 px-6 py-8 lg:px-12 max-w-6xl mx-auto w-full relative">
        <div class="animate-fade-in">
            <div
                class="flex flex-col md:flex-row justify-between items-end mb-10 gap-4"
            >
                <div>
                    <h1
                        class="font-bold text-4xl text-slate-dark tracking-tight"
                    >
                        Savings Goals
                    </h1>
                    <p class="text-slate-500 font-medium mt-2">
                        Track your progress towards your dreams.
                    </p>
                </div>
                <button
                    onclick="window.openGoalModal()"
                    class="bg-indigo text-white font-bold py-3 px-6 rounded-xl shadow-tactile hover:shadow-tactile-hover hover:translate-y-0.5 transition-all flex items-center gap-2"
                >
                    <span class="material-symbols-outlined">add</span>
                    New Goal
                </button>
            </div>
            <div
                class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 mb-16"
                id="goals-container"
            >
                <!-- Goals will be injected here -->
                <button
                    onclick="window.openGoalModal()"
                    class="rounded-3xl p-8 border-4 border-dashed border-slate-200 flex flex-col items-center justify-center text-slate-400 hover:border-indigo hover:text-indigo hover:bg-indigo-bg/30 transition-all min-h-[460px] group cursor-pointer"
                >
                    <div
                        class="w-20 h-20 rounded-full bg-slate-100 group-hover:bg-indigo group-hover:text-white flex items-center justify-center mb-4 transition-colors"
                    >
                        <span class="material-symbols-outlined text-4xl"
                            >add</span
                        >
                    </div>
                    <span class="text-xl font-bold">Create New Goal</span>
                    <span class="text-sm font-medium mt-2 opacity-70"
                        >Start saving for something new</span
                    >
                </button>
            </div>
            <div class="flex justify-between items-end mb-8">
                <div>
                    <h2
                        class="font-bold text-3xl text-slate-dark tracking-tight"
                    >
                        Monthly Budgets
                    </h2>
                    <p class="text-slate-500 font-medium mt-2">
                        Manage your spending limits.
                    </p>
                </div>
                <button
                    onclick="window.openBudgetModal()"
                    class="text-indigo font-bold hover:underline"
                    >Manage Categories</button
                >
            </div>
            <div
                class="grid grid-cols-1 lg:grid-cols-2 gap-8"
                id="budgets-container"
            >
                <!-- Budgets will be injected here -->
            </div>
        </div>
    </main>
    <GoalModal />
    <BudgetModal />
    <AddFundsModal />
</Layout>

<script>
    import {
        getGoals,
        getBudgets,
        getTransactions,
        formatCurrency,
        parseLocalDate,
    } from "../utils/store";

    async function renderGoalsAndBudgets() {
        const goalsContainer = document.getElementById("goals-container");
        const budgetsContainer = document.getElementById("budgets-container");

        if (!goalsContainer || !budgetsContainer) return;

        const [goals, budgets, transactions] = await Promise.all([
            getGoals(),
            getBudgets(),
            getTransactions(),
        ]);

        // Calculate actual spending per category for budgets
        const spendingByCategory: Record<string, number> = {};
        transactions.forEach((t) => {
            if (t.type === "expense") {
                spendingByCategory[t.category] =
                    (spendingByCategory[t.category] || 0) + t.amount;
            }
        });

        // 1. Render Goals
        // Generate the "Add New" button first
        const addNewBtn = `
            <button
                onclick="window.openGoalModal()"
                class="rounded-3xl p-8 border-4 border-dashed border-slate-200 flex flex-col items-center justify-center text-slate-400 hover:border-indigo hover:text-indigo hover:bg-indigo-bg/30 transition-all min-h-[460px] group cursor-pointer lg:order-last"
            >
                <div class="w-20 h-20 rounded-full bg-slate-100 group-hover:bg-indigo group-hover:text-white flex items-center justify-center mb-4 transition-colors">
                    <span class="material-symbols-outlined text-4xl">add</span>
                </div>
                <span class="text-xl font-bold">Create New Goal</span>
                <span class="text-sm font-medium mt-2 opacity-70">Start saving for something new</span>
            </button>
        `;

        goalsContainer.innerHTML =
            goals
                .map((g) => {
                    const progress =
                        Math.min(
                            100,
                            Math.round((g.current / g.amount) * 100),
                        ) || 0;
                    const dashoffset = 251.2 - (251.2 * progress) / 100;
                    const remaining = Math.max(0, g.amount - g.current);

                    return `
            <div class="bg-white rounded-3xl p-8 shadow-card border border-slate-100 flex flex-col items-center relative overflow-hidden group hover:border-indigo-200 transition-colors">
                <div class="absolute top-4 right-4 z-10">
                    <button 
                        onclick="window.openGoalModal('${g.id}')"
                        class="text-slate-300 hover:text-indigo transition-colors p-2"
                        title="Edit or Delete Goal"
                    >
                        <span class="material-symbols-outlined">more_vert</span>
                    </button>
                </div>
                <div class="relative w-48 h-48 mb-6">
                    <svg class="w-full h-full" viewBox="0 0 100 100">
                        <circle class="text-slate-100 stroke-current" cx="50" cy="50" fill="transparent" r="40" stroke-width="8"></circle>
                        <circle class="text-indigo progress-ring-circle stroke-current" cx="50" cy="50" fill="transparent" r="40" stroke-dasharray="251.2" stroke-dashoffset="${dashoffset}" stroke-linecap="round" stroke-width="8"></circle>
                    </svg>
                    <div class="absolute inset-0 flex items-center justify-center flex-col">
                        <span class="material-symbols-outlined text-4xl text-indigo mb-1">${g.icon}</span>
                        <span class="font-mono text-3xl font-bold text-slate-dark">${progress}%</span>
                    </div>
                </div>
                <h3 class="text-2xl font-bold text-slate-dark mb-1">${g.name}</h3>
                <p class="text-slate-400 font-medium text-sm mb-6">Target: ${parseLocalDate(g.date).toLocaleDateString("default", { month: "short", year: "numeric" })}</p>
                <div class="w-full grid grid-cols-2 gap-4 text-center">
                    <div class="bg-slate-50 p-3 rounded-xl border border-slate-100">
                        <span class="block text-xs font-bold text-slate-400 uppercase tracking-wider mb-1">Current</span>
                        <span class="font-mono text-lg font-bold text-indigo">${formatCurrency(g.current)}</span>
                    </div>
                    <div class="bg-slate-50 p-3 rounded-xl border border-slate-100">
                        <span class="block text-xs font-bold text-slate-400 uppercase tracking-wider mb-1">Target</span>
                        <span class="font-mono text-lg font-bold text-slate-dark">${formatCurrency(g.amount)}</span>
                    </div>
                </div>
                <div class="mt-4 w-full text-center">
                    <span class="text-xs font-bold text-slate-400 uppercase tracking-wider">Remaining Balance: </span>
                    <span class="font-mono text-sm font-bold text-slate-500">${formatCurrency(remaining)}</span>
                </div>
                <button 
                    onclick="window.openAddFundsModal('${g.id}')"
                    class="mt-6 w-full py-3 bg-indigo text-white font-bold rounded-xl hover:opacity-90 transition-all shadow-sm"
                >
                    Add Funds
                </button>
            </div>
            `;
                })
                .join("") + addNewBtn;

        // 2. Render Budgets
        const categoryMap: Record<
            string,
            { label: string; icon: string; color: string; bg: string }
        > = {
            dining: {
                label: "Dining Out",
                icon: "restaurant",
                color: "text-indigo",
                bg: "bg-indigo-bg",
            },
            shopping: {
                label: "Shopping",
                icon: "shopping_bag",
                color: "text-orange",
                bg: "bg-orange-bg",
            },
            transportation: {
                label: "Transportation",
                icon: "local_gas_station",
                color: "text-indigo",
                bg: "bg-indigo-bg",
            },
            entertainment: {
                label: "Entertainment",
                icon: "movie",
                color: "text-orange",
                bg: "bg-orange-bg",
            },
        };

        budgetsContainer.innerHTML = Object.entries(categoryMap)
            .map(([key, info]) => {
                const limit = budgets[key] || 0;
                const spent = spendingByCategory[key] || 0;
                const progress =
                    limit > 0
                        ? Math.min(100, Math.round((spent / limit) * 100))
                        : 0;
                const remaining = Math.max(0, limit - spent);
                const barColor = info.color.replace("text-", "bg-");

                return `
            <div class="bg-white rounded-2xl p-6 shadow-card border border-slate-100">
                <div class="flex justify-between items-center mb-4">
                    <div class="flex items-center gap-4">
                        <div class="w-12 h-12 rounded-xl ${info.bg} flex items-center justify-center ${info.color}">
                            <span class="material-symbols-outlined">${info.icon}</span>
                        </div>
                        <div>
                            <h4 class="font-bold text-lg text-slate-dark">${info.label}</h4>
                            <p class="text-xs font-bold text-slate-400 uppercase">Monthly Limit</p>
                        </div>
                    </div>
                    <div class="text-right">
                        <span class="font-mono text-2xl font-bold text-slate-dark">${formatCurrency(spent)}</span>
                        <span class="font-mono text-sm text-slate-400"> / ${formatCurrency(limit)}</span>
                    </div>
                </div>
                <div class="relative h-4 w-full bg-slate-100 rounded-full overflow-hidden">
                    <div class="absolute h-full ${barColor} rounded-full progress-bar-fill" style="width: ${progress}%"></div>
                </div>
                <div class="flex justify-between mt-2 text-sm font-medium">
                    <span class="${info.color} font-bold">${progress}% Used</span>
                    <span class="text-slate-400">${formatCurrency(remaining)} remaining</span>
                </div>
            </div>
            `;
            })
            .join("");
    }

    document.addEventListener("astro:page-load", renderGoalsAndBudgets);
    window.addEventListener("goals-updated", renderGoalsAndBudgets);
    window.addEventListener("budgets-updated", renderGoalsAndBudgets);
    window.addEventListener("transactions-updated", renderGoalsAndBudgets);
</script>
