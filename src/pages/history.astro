---
import Layout from "../layouts/Layout.astro";
import Navbar from "../components/Navbar.astro";
import BalanceCard from "../components/BalanceCard.astro";
import TransactionModal from "../components/modals/TransactionModal.astro";
---

<Layout title="Activity Feed - Vibrant Ledger">
    <Navbar />
    <main class="flex-1 px-6 py-8 lg:px-12 max-w-6xl mx-auto w-full relative">
        <div class="animate-fade-in">
            <div
                class="mb-10 flex flex-col md:flex-row md:items-center justify-between gap-6"
            >
                <div>
                    <h1 class="text-4xl font-bold text-slate-dark mb-2">
                        Activity Feed
                    </h1>
                    <p class="text-slate-500 font-medium">
                        Track your financial journey.
                    </p>
                </div>
                <div class="flex flex-col sm:flex-row gap-4 w-full md:w-auto">
                    <div class="relative flex-1 sm:w-64">
                        <span
                            class="absolute inset-y-0 left-0 flex items-center pl-3 text-slate-400"
                        >
                            <span class="material-symbols-outlined">search</span
                            >
                        </span>
                        <input
                            id="search-input"
                            class="w-full py-3 pl-10 pr-4 rounded-xl border-2 border-slate-200 focus:border-indigo focus:ring-0 text-slate-dark font-medium bg-white shadow-sm placeholder-slate-400"
                            placeholder="Search transactions..."
                            type="text"
                        />
                    </div>
                </div>
            </div>
            <div class="flex flex-wrap gap-3 mb-12" id="filter-buttons">
                <button
                    data-filter="all"
                    class="filter-btn active bg-indigo text-white px-5 py-2.5 rounded-full font-bold shadow-tactile hover:shadow-tactile-hover hover:translate-y-[1px] transition-all flex items-center gap-2"
                >
                    <span>All</span>
                </button>
                <button
                    data-filter="food"
                    class="filter-btn bg-white text-orange border-2 border-orange px-5 py-2.5 rounded-full font-bold shadow-sm hover:bg-orange hover:text-white transition-colors flex items-center gap-2"
                >
                    <span class="material-symbols-outlined text-[20px]"
                        >restaurant</span
                    >
                    Food
                </button>
                <button
                    data-filter="income"
                    class="filter-btn bg-white text-teal border-2 border-teal px-5 py-2.5 rounded-full font-bold shadow-sm hover:bg-teal hover:text-white transition-colors flex items-center gap-2"
                >
                    <span class="material-symbols-outlined text-[20px]"
                        >payments</span
                    >
                    Income
                </button>
                <button
                    data-filter="shopping"
                    class="filter-btn bg-white text-pink border-2 border-pink px-5 py-2.5 rounded-full font-bold shadow-sm hover:bg-pink hover:text-white transition-colors flex items-center gap-2"
                >
                    <span class="material-symbols-outlined text-[20px]"
                        >shopping_bag</span
                    >
                    Shopping
                </button>
                <button
                    data-filter="savings"
                    class="filter-btn bg-white text-emerald-600 border-2 border-emerald-600 px-5 py-2.5 rounded-full font-bold shadow-sm hover:bg-emerald-600 hover:text-white transition-colors flex items-center gap-2"
                >
                    <span class="material-symbols-outlined text-[20px]"
                        >savings</span
                    >
                    Savings
                </button>
            </div>
            <div class="flex flex-col lg:flex-row gap-8 items-start">
                <div class="flex-1 w-full space-y-8" id="history-container">
                    <!-- Transactions grouped by month will be injected here -->
                    <div class="py-20 text-center text-slate-400">
                        <span
                            class="material-symbols-outlined text-6xl mb-4 block opacity-20"
                            >history</span
                        >
                        <h3 class="text-xl font-bold text-slate- dark">
                            No transactions yet
                        </h3>
                        <p class="mt-1">
                            Add your first transaction from the dashboard.
                        </p>
                    </div>
                </div>
                <div
                    class="lg:w-80 w-full flex-shrink-0 order-first lg:order-last"
                >
                    <div
                        class="bg-indigo text-white rounded-3xl p-6 shadow-floating sticky top-32 overflow-hidden relative"
                    >
                        <div
                            class="absolute right-0 top-0 w-32 h-32 bg-white opacity-10 rounded-full -mr-10 -mt-10 pointer-events-none"
                        >
                        </div>
                        <div
                            class="absolute left-0 bottom-0 w-24 h-24 bg-orange opacity-20 rounded-full -ml-8 -mb-8 pointer-events-none"
                        >
                        </div>
                        <h3
                            class="text-lg font-bold mb-6 flex items-center gap-2 relative z-10"
                        >
                            <span class="material-symbols-outlined"
                                >analytics</span
                            >
                            Quick Stats
                        </h3>
                        <div class="space-y-6 relative z-10">
                            <div>
                                <p
                                    class="text-indigo-200 text-xs font-bold uppercase tracking-widest mb-1"
                                >
                                    Total Spent
                                </p>
                                <p
                                    class="font-mono text-4xl font-bold tracking-tight text-white"
                                    id="total-spent-stat"
                                >
                                    $0.00
                                </p>
                                <div
                                    class="w-full bg-indigo-dark/50 h-1.5 rounded-full mt-2 overflow-hidden"
                                >
                                    <div
                                        class="bg-orange h-full rounded-full"
                                        style="width: 0%"
                                        id="spent-progress"
                                    >
                                    </div>
                                </div>
                            </div>
                            <div>
                                <p
                                    class="text-indigo-200 text-xs font-bold uppercase tracking-widest mb-1"
                                >
                                    Total Earned
                                </p>
                                <p
                                    class="font-mono text-4xl font-bold tracking-tight text-teal-light"
                                    id="total-earned-stat"
                                >
                                    $0.00
                                </p>
                                <div
                                    class="w-full bg-indigo-dark/50 h-1.5 rounded-full mt-2 overflow-hidden"
                                >
                                    <div
                                        class="bg-teal h-full rounded-full"
                                        style="width: 0%"
                                        id="earned-progress"
                                    >
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div
                            class="mt-8 pt-6 border-t border-white/10 relative z-10"
                        >
                            <p class="text-indigo-200 text-sm mb-3">
                                Viewing <span class="text-white font-bold"
                                    >All Transactions</span
                                > to date.
                            </p>
                            <button
                                id="export-report-btn"
                                class="w-full bg-white text-indigo font-bold py-3 rounded-xl hover:bg-indigo-50 transition-colors shadow-tactile hover:shadow-tactile-hover hover:translate-y-[1px] flex items-center justify-center gap-2"
                            >
                                <span class="material-symbols-outlined text-lg"
                                    >download</span
                                >
                                Export Report
                            </button>
                            <button
                                id="clear-all-btn"
                                class="w-full mt-3 bg-red-50 text-red-600 font-bold py-3 rounded-xl hover:bg-red-100 transition-colors flex items-center justify-center gap-2 border border-red-100"
                            >
                                <span class="material-symbols-outlined text-lg"
                                    >delete_sweep</span
                                >
                                Clear All History
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </main>
    <TransactionModal />
</Layout>

<script>
    import {
        getTransactions,
        formatCurrency,
        getBalanceOverview,
        parseLocalDate,
        resetAllData,
        isUserAdmin,
    } from "../utils/store";

    let currentFilter = "all";
    let searchQuery = "";

    async function renderHistory() {
        const isAdmin = await isUserAdmin();
        const clearBtn = document.getElementById("clear-history-btn");
        if (clearBtn) {
            clearBtn.style.display = isAdmin ? "flex" : "none";
        }
        const container = document.getElementById("history-container");
        if (!container) return;

        const [transactionsRaw, overview] = await Promise.all([
            getTransactions(),
            getBalanceOverview(),
        ]);
        let transactions = [...transactionsRaw];

        // Update Stats
        const spentStat = document.getElementById("total-spent-stat");
        const earnedStat = document.getElementById("total-earned-stat");
        const spentProgress = document.getElementById("spent-progress");
        const earnedProgress = document.getElementById("earned-progress");

        if (spentStat)
            spentStat.textContent = formatCurrency(overview.totalExpense);
        if (earnedStat)
            earnedStat.textContent = formatCurrency(overview.totalIncome);

        if (spentProgress || earnedProgress) {
            const total = overview.totalIncome + overview.totalExpense;
            if (total > 0) {
                if (spentProgress)
                    spentProgress.style.width = `${(overview.totalExpense / total) * 100}%`;
                if (earnedProgress)
                    earnedProgress.style.width = `${(overview.totalIncome / total) * 100}%`;
            }
        }

        // Apply Filters
        if (currentFilter !== "all") {
            if (currentFilter === "income") {
                transactions = transactions.filter((t) => t.type === "income");
            } else {
                transactions = transactions.filter(
                    (t) => t.category === currentFilter,
                );
            }
        }

        // Apply Search
        if (searchQuery) {
            const q = searchQuery.toLowerCase();
            transactions = transactions.filter(
                (t) =>
                    t.note.toLowerCase().includes(q) ||
                    t.category.toLowerCase().includes(q),
            );
        }

        if (transactions.length === 0) {
            container.innerHTML = `
                <div class="py-20 text-center text-slate-400">
                    <span class="material-symbols-outlined text-6xl mb-4 block opacity-20">history</span>
                    <h3 class="text-xl font-bold text-slate-dark">No transactions found</h3>
                    <p class="mt-1">${searchQuery || currentFilter !== "all" ? "Try adjusting your filters" : "Add your first transaction from the dashboard."}</p>
                </div>
            `;
            return;
        }

        // Group by month
        const groups: Record<string, any[]> = {};
        transactions.forEach((t) => {
            const date = parseLocalDate(t.date);
            const month = date.toLocaleString("default", {
                month: "long",
                year: "numeric",
            });
            if (!groups[month]) groups[month] = [];
            groups[month].push(t);
        });

        const categoryIcons: Record<string, string> = {
            food: "restaurant",
            shopping: "shopping_bag",
            transportation: "directions_car",
            bills: "bolt",
            entertainment: "movie",
            salary: "work",
            freelance: "laptop_mac",
            investments: "show_chart",
            other: "package",
            other_income: "redeem",
            savings: "savings",
        };

        const categoryColors: Record<string, string> = {
            salary: "bg-indigo",
            freelance: "bg-indigo",
            investments: "bg-indigo",
            other_income: "bg-indigo",
            food: "bg-orange",
            shopping: "bg-pink-500",
            transportation: "bg-orange",
            bills: "bg-indigo",
            entertainment: "bg-purple-500",
            other: "bg-slate-500",
            savings: "bg-emerald-500",
        };

        const iconBgColors: Record<string, string> = {
            income: "bg-indigo/10 text-indigo",
            expense: "bg-orange/10 text-orange",
            savings: "bg-emerald-50 text-emerald-600",
        };

        container.innerHTML = Object.entries(groups)
            .map(([month, txs]) => {
                let monthIncome = 0;
                let monthExpense = 0;
                txs.forEach((t) => {
                    if (t.type === "income") monthIncome += t.amount;
                    else monthExpense += t.amount;
                });
                const monthNet = monthIncome - monthExpense;

                return `
            <div class="mb-12">
                <div class="flex flex-col md:flex-row md:items-end justify-between mb-6 border-l-8 border-indigo pl-4 gap-4">
                    <h3 class="text-3xl font-sans font-bold text-slate-dark dark:text-white">
                        ${month}
                    </h3>
                    <div class="flex items-center gap-4 bg-white dark:bg-slate-800/80 backdrop-blur-sm p-2 px-5 rounded-2xl border border-slate-200 dark:border-slate-700 shadow-sm">
                        <div class="flex flex-col">
                            <span class="text-[10px] font-bold text-slate-500 dark:text-slate-400 uppercase tracking-wider">Income</span>
                            <span class="font-bold text-sm text-indigo dark:text-indigo-400">${formatCurrency(monthIncome)}</span>
                        </div>
                        <div class="w-px h-6 bg-slate-200 dark:bg-slate-700"></div>
                        <div class="flex flex-col">
                            <span class="text-[10px] font-bold text-slate-500 dark:text-slate-400 uppercase tracking-wider">Expense</span>
                            <span class="font-bold text-sm text-orange dark:text-orange-400">${formatCurrency(monthExpense)}</span>
                        </div>
                        <div class="w-px h-6 bg-slate-200 dark:bg-slate-700"></div>
                        <div class="flex flex-col">
                            <span class="text-[10px] font-bold text-slate-500 dark:text-slate-400 uppercase tracking-wider">Net</span>
                            <span class="${monthNet >= 0 ? "text-indigo dark:text-indigo-400" : "text-orange dark:text-orange-400"} font-bold text-sm">${formatCurrency(monthNet)}</span>
                        </div>
                    </div>
                </div>
                <div class="space-y-4">
                    ${txs
                        .map((t) => {
                            const category = t.category || "other";
                            const icon = categoryIcons[category] || "payments";
                            const badgeColor =
                                categoryColors[category] || "bg-slate-500";
                            const iconStyle =
                                iconBgColors[
                                    category === "savings" ? "savings" : t.type
                                ] || "bg-slate-100 text-slate-500";
                            const prefix = t.type === "expense" ? "-" : "+";
                            const amountClass =
                                t.type === "expense"
                                    ? "text-slate-dark"
                                    : "text-indigo";
                            const formattedDate = parseLocalDate(
                                t.date,
                            ).toLocaleDateString("default", {
                                day: "numeric",
                                month: "short",
                            });

                            const destination =
                                t.category === "savings" ? "/goals" : "/";

                            return `
                        <div 
                            onclick="window.openTransactionModal('${t.id}')"
                            class="bg-white rounded-2xl p-5 shadow-card border border-slate-100 flex flex-col sm:flex-row sm:items-center justify-between gap-4 hover:border-indigo transition-colors cursor-pointer group"
                        >
                            <div class="flex items-center gap-5">
                                <div class="w-16 h-16 ${iconStyle} rounded-2xl flex flex-shrink-0 items-center justify-center shadow-sm group-hover:scale-105 transition-transform duration-300">
                                    <span class="material-symbols-outlined text-3xl">${icon}</span>
                                </div>
                                <div>
                                    <h4 class="font-bold text-xl text-slate-dark">${t.note || category.charAt(0).toUpperCase() + category.slice(1).replace("_", " ")}</h4>
                                    <div class="flex items-center gap-2 mt-1">
                                        <span class="px-2.5 py-1 rounded-md ${badgeColor} text-white text-xs font-bold uppercase tracking-wider">${category.replace("_", " ")}</span>
                                        <span class="text-slate-400 text-sm font-medium">${formattedDate}</span>
                                    </div>
                                </div>
                            </div>
                            <div class="text-right pl-20 sm:pl-0">
                                <p class="font-mono text-2xl font-bold ${amountClass}">${prefix}${formatCurrency(t.amount)}</p>
                                <p class="text-slate-400 text-sm font-medium">Verified Transaction</p>
                            </div>
                        </div>
                        `;
                        })
                        .join("")}
                </div>
            </div>
        `;
            })
            .join("");
    }

    function initHistory() {
        const searchInput = document.getElementById(
            "search-input",
        ) as HTMLInputElement;
        const filterBtns = document.querySelectorAll(".filter-btn");

        searchInput?.addEventListener("input", (e) => {
            searchQuery = (e.target as HTMLInputElement).value;
            renderHistory();
        });

        filterBtns.forEach((btn) => {
            btn.addEventListener("click", () => {
                // Update active state UI
                filterBtns.forEach((b) => {
                    b.classList.remove("active", "bg-indigo", "text-white");
                    b.classList.add("bg-white");
                    // Restore original border colors based on filter
                    const f = b.getAttribute("data-filter");
                    if (f === "food")
                        b.classList.add("text-orange", "border-orange");
                    if (f === "income")
                        b.classList.add("text-teal", "border-teal");
                    if (f === "shopping")
                        b.classList.add("text-pink", "border-pink");
                    if (f === "savings")
                        b.classList.add(
                            "text-emerald-600",
                            "border-emerald-600",
                        );
                });

                btn.classList.add("active", "bg-indigo", "text-white");
                btn.classList.remove(
                    "bg-white",
                    "text-orange",
                    "text-teal",
                    "text-pink",
                    "text-emerald-600",
                    "border-orange",
                    "border-teal",
                    "border-pink",
                    "border-emerald-600",
                );

                currentFilter = btn.getAttribute("data-filter") || "all";
                renderHistory();
            });
        });

        renderHistory();
    }

    async function exportCSV() {
        const transactions = await getTransactions();
        if (transactions.length === 0) {
            alert("No transactions to export.");
            return;
        }

        const headers = ["Date", "Type", "Category", "Amount (COP)", "Note"];
        const rows = transactions.map((t) => {
            const date = parseLocalDate(t.date).toLocaleDateString("es-CO", {
                day: "2-digit",
                month: "2-digit",
                year: "numeric",
            });
            const amount = t.type === "expense" ? -t.amount : t.amount;
            const category = t.category || "other";
            const note = (t.note || "").replace(/"/g, '""');
            return `"${date}","${t.type}","${category.replace("_", " ")}","${amount}","${note}"`;
        });

        const overview = await getBalanceOverview();
        rows.push("");
        rows.push(`"Total Income",,,,"${overview.totalIncome}"`);
        rows.push(`"Total Expenses",,,,"${overview.totalExpense}"`);
        rows.push(`"Net Balance",,,,"${overview.totalBalance}"`);

        const csv = [headers.join(","), ...rows].join("\n");
        const blob = new Blob([`\uFEFF${csv}`], {
            type: "text/csv;charset=utf-8;",
        });
        const url = URL.createObjectURL(blob);
        const link = document.createElement("a");
        const now = new Date();
        const filename = `transactions_${now.getFullYear()}-${String(now.getMonth() + 1).padStart(2, "0")}-${String(now.getDate()).padStart(2, "0")}.csv`;
        link.href = url;
        link.download = filename;
        link.click();
        URL.revokeObjectURL(url);
    }

    function initExport() {
        const btn = document.getElementById("export-report-btn");
        btn?.addEventListener("click", () => exportCSV());
    }

    function initClear() {
        const btn = document.getElementById("clear-all-btn");
        btn?.addEventListener("click", async () => {
            if (
                confirm(
                    "Are you sure you want to clear ALL your transaction history? This will also reset your savings progress.",
                )
            ) {
                await resetAllData();
                renderHistory();
            }
        });
    }

    document.addEventListener("astro:page-load", () => {
        initHistory();
        initExport();
        initClear();
    });

    if (!(window as any).hasHistoryListener) {
        window.addEventListener("transactions-updated", () => {
            // In history page, we just need to re-render if we are on the page
            const container = document.getElementById("history-container");
            if (container) renderHistory();
        });
        (window as any).hasHistoryListener = true;
    }
</script>
