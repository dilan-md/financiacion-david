---
import Layout from "../layouts/Layout.astro";
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";
---

<Layout title="Activity Feed - Vibrant Ledger">
    <Navbar />
    <main class="flex-1 px-6 py-8 lg:px-12 max-w-6xl mx-auto w-full relative">
        <div class="animate-fade-in">
            <div
                class="mb-10 flex flex-col md:flex-row md:items-center justify-between gap-6"
            >
                <div>
                    <h1 class="text-4xl font-bold text-slate-dark mb-2">
                        Activity Feed
                    </h1>
                    <p class="text-slate-500 font-medium">
                        Track your financial journey.
                    </p>
                </div>
                <div class="flex flex-col sm:flex-row gap-4 w-full md:w-auto">
                    <div class="relative flex-1 sm:w-64">
                        <span
                            class="absolute inset-y-0 left-0 flex items-center pl-3 text-slate-400"
                        >
                            <span class="material-symbols-outlined">search</span
                            >
                        </span>
                        <input
                            class="w-full py-3 pl-10 pr-4 rounded-xl border-2 border-slate-200 focus:border-indigo focus:ring-0 text-slate-dark font-medium bg-white shadow-sm placeholder-slate-400"
                            placeholder="Search transactions..."
                            type="text"
                        />
                    </div>
                </div>
            </div>
            <div class="flex flex-wrap gap-3 mb-12">
                <button
                    class="bg-indigo text-white px-5 py-2.5 rounded-full font-bold shadow-tactile hover:shadow-tactile-hover hover:translate-y-[1px] transition-all flex items-center gap-2"
                >
                    <span>All</span>
                </button>
                <button
                    class="bg-white text-orange border-2 border-orange px-5 py-2.5 rounded-full font-bold shadow-sm hover:bg-orange hover:text-white transition-colors flex items-center gap-2"
                >
                    <span class="material-symbols-outlined text-[20px]"
                        >restaurant</span
                    >
                    Food
                </button>
                <button
                    class="bg-white text-teal border-2 border-teal px-5 py-2.5 rounded-full font-bold shadow-sm hover:bg-teal hover:text-white transition-colors flex items-center gap-2"
                >
                    <span class="material-symbols-outlined text-[20px]"
                        >payments</span
                    >
                    Income
                </button>
                <button
                    class="bg-white text-pink border-2 border-pink px-5 py-2.5 rounded-full font-bold shadow-sm hover:bg-pink hover:text-white transition-colors flex items-center gap-2"
                >
                    <span class="material-symbols-outlined text-[20px]"
                        >shopping_bag</span
                    >
                    Shopping
                </button>
                <button
                    class="bg-white text-slate-400 border-2 border-slate-200 px-5 py-2.5 rounded-full font-bold shadow-sm hover:border-slate-400 hover:text-slate-600 transition-colors flex items-center gap-2"
                >
                    <span class="material-symbols-outlined text-[20px]"
                        >add</span
                    >
                    More
                </button>
            </div>
            <div class="flex flex-col lg:flex-row gap-8 items-start">
                <div class="flex-1 w-full space-y-8">
                    <div>
                        <h3
                            class="text-3xl font-sans font-bold text-slate-dark mb-6 border-l-8 border-indigo pl-4"
                        >
                            August 2024
                        </h3>
                        <div class="space-y-4">
                            <div
                                class="bg-white rounded-2xl p-5 shadow-card border border-slate-100 flex flex-col sm:flex-row sm:items-center justify-between gap-4 hover:border-indigo transition-colors cursor-pointer group"
                            >
                                <div class="flex items-center gap-5">
                                    <div
                                        class="w-16 h-16 bg-orange/10 text-orange rounded-2xl flex flex-shrink-0 items-center justify-center shadow-sm group-hover:scale-105 transition-transform duration-300"
                                    >
                                        <span
                                            class="material-symbols-outlined text-3xl"
                                            >restaurant</span
                                        >
                                    </div>
                                    <div>
                                        <h4
                                            class="font-bold text-xl text-slate-dark"
                                        >
                                            Bistrot Leo
                                        </h4>
                                        <div
                                            class="flex items-center gap-2 mt-1"
                                        >
                                            <span
                                                class="px-2.5 py-1 rounded-md bg-orange text-white text-xs font-bold uppercase tracking-wider"
                                                >Food</span
                                            >
                                            <span
                                                class="text-slate-400 text-sm font-medium"
                                                >Aug 24, 8:30 PM</span
                                            >
                                        </div>
                                    </div>
                                </div>
                                <div class="text-right pl-20 sm:pl-0">
                                    <p
                                        class="font-mono text-2xl font-bold text-slate-dark"
                                    >
                                        -$85.00
                                    </p>
                                    <p
                                        class="text-slate-400 text-sm font-medium"
                                    >
                                        Credit Card •••• 4242
                                    </p>
                                </div>
                            </div>
                            <div
                                class="bg-white rounded-2xl p-5 shadow-card border border-slate-100 flex flex-col sm:flex-row sm:items-center justify-between gap-4 hover:border-indigo transition-colors cursor-pointer group"
                            >
                                <div class="flex items-center gap-5">
                                    <div
                                        class="w-16 h-16 bg-teal/10 text-teal rounded-2xl flex flex-shrink-0 items-center justify-center shadow-sm group-hover:scale-105 transition-transform duration-300"
                                    >
                                        <span
                                            class="material-symbols-outlined text-3xl"
                                            >work</span
                                        >
                                    </div>
                                    <div>
                                        <h4
                                            class="font-bold text-xl text-slate-dark"
                                        >
                                            Freelance Project
                                        </h4>
                                        <div
                                            class="flex items-center gap-2 mt-1"
                                        >
                                            <span
                                                class="px-2.5 py-1 rounded-md bg-teal text-white text-xs font-bold uppercase tracking-wider"
                                                >Income</span
                                            >
                                            <span
                                                class="text-slate-400 text-sm font-medium"
                                                >Aug 22, 10:00 AM</span
                                            >
                                        </div>
                                    </div>
                                </div>
                                <div class="text-right pl-20 sm:pl-0">
                                    <p
                                        class="font-mono text-2xl font-bold text-teal"
                                    >
                                        +$1,500.00
                                    </p>
                                    <p
                                        class="text-slate-400 text-sm font-medium"
                                    >
                                        Direct Deposit
                                    </p>
                                </div>
                            </div>
                            <div
                                class="bg-white rounded-2xl p-5 shadow-card border border-slate-100 flex flex-col sm:flex-row sm:items-center justify-between gap-4 hover:border-indigo transition-colors cursor-pointer group"
                            >
                                <div class="flex items-center gap-5">
                                    <div
                                        class="w-16 h-16 bg-pink-100 text-pink-600 rounded-2xl flex flex-shrink-0 items-center justify-center shadow-sm group-hover:scale-105 transition-transform duration-300"
                                    >
                                        <span
                                            class="material-symbols-outlined text-3xl"
                                            >shopping_bag</span
                                        >
                                    </div>
                                    <div>
                                        <h4
                                            class="font-bold text-xl text-slate-dark"
                                        >
                                            Uniqlo Store
                                        </h4>
                                        <div
                                            class="flex items-center gap-2 mt-1"
                                        >
                                            <span
                                                class="px-2.5 py-1 rounded-md bg-pink-500 text-white text-xs font-bold uppercase tracking-wider"
                                                >Shopping</span
                                            >
                                            <span
                                                class="text-slate-400 text-sm font-medium"
                                                >Aug 20, 4:15 PM</span
                                            >
                                        </div>
                                    </div>
                                </div>
                                <div class="text-right pl-20 sm:pl-0">
                                    <p
                                        class="font-mono text-2xl font-bold text-slate-dark"
                                    >
                                        -$124.50
                                    </p>
                                    <p
                                        class="text-slate-400 text-sm font-medium"
                                    >
                                        Debit Card •••• 8812
                                    </p>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="mt-12">
                        <h3
                            class="text-3xl font-sans font-bold text-slate-dark mb-6 border-l-8 border-slate-300 pl-4 text-slate-400"
                        >
                            July 2024
                        </h3>
                        <div
                            class="space-y-4 opacity-80 hover:opacity-100 transition-opacity"
                        >
                            <div
                                class="bg-white rounded-2xl p-5 shadow-card border border-slate-100 flex flex-col sm:flex-row sm:items-center justify-between gap-4 hover:border-indigo transition-colors cursor-pointer group"
                            >
                                <div class="flex items-center gap-5">
                                    <div
                                        class="w-16 h-16 bg-indigo/10 text-indigo rounded-2xl flex flex-shrink-0 items-center justify-center shadow-sm group-hover:scale-105 transition-transform duration-300"
                                    >
                                        <span
                                            class="material-symbols-outlined text-3xl"
                                            >bolt</span
                                        >
                                    </div>
                                    <div>
                                        <h4
                                            class="font-bold text-xl text-slate-dark"
                                        >
                                            Electric Company
                                        </h4>
                                        <div
                                            class="flex items-center gap-2 mt-1"
                                        >
                                            <span
                                                class="px-2.5 py-1 rounded-md bg-indigo text-white text-xs font-bold uppercase tracking-wider"
                                                >Utilities</span
                                            >
                                            <span
                                                class="text-slate-400 text-sm font-medium"
                                                >Jul 28, 9:00 AM</span
                                            >
                                        </div>
                                    </div>
                                </div>
                                <div class="text-right pl-20 sm:pl-0">
                                    <p
                                        class="font-mono text-2xl font-bold text-slate-dark"
                                    >
                                        -$145.20
                                    </p>
                                    <p
                                        class="text-slate-400 text-sm font-medium"
                                    >
                                        Auto Pay
                                    </p>
                                </div>
                            </div>
                            <div
                                class="bg-white rounded-2xl p-5 shadow-card border border-slate-100 flex flex-col sm:flex-row sm:items-center justify-between gap-4 hover:border-indigo transition-colors cursor-pointer group"
                            >
                                <div class="flex items-center gap-5">
                                    <div
                                        class="w-16 h-16 bg-orange/10 text-orange rounded-2xl flex flex-shrink-0 items-center justify-center shadow-sm group-hover:scale-105 transition-transform duration-300"
                                    >
                                        <span
                                            class="material-symbols-outlined text-3xl"
                                            >local_gas_station</span
                                        >
                                    </div>
                                    <div>
                                        <h4
                                            class="font-bold text-xl text-slate-dark"
                                        >
                                            Shell Station
                                        </h4>
                                        <div
                                            class="flex items-center gap-2 mt-1"
                                        >
                                            <span
                                                class="px-2.5 py-1 rounded-md bg-orange text-white text-xs font-bold uppercase tracking-wider"
                                                >Transport</span
                                            >
                                            <span
                                                class="text-slate-400 text-sm font-medium"
                                                >Jul 25, 6:45 PM</span
                                            >
                                        </div>
                                    </div>
                                </div>
                                <div class="text-right pl-20 sm:pl-0">
                                    <p
                                        class="font-mono text-2xl font-bold text-slate-dark"
                                    >
                                        -$45.00
                                    </p>
                                    <p
                                        class="text-slate-400 text-sm font-medium"
                                    >
                                        Debit Card •••• 8812
                                    </p>
                                </div>
                            </div>
                        </div>
                        <div class="mt-8 text-center">
                            <button
                                class="px-8 py-3 bg-slate-200 text-slate-600 hover:bg-indigo hover:text-white font-bold rounded-xl transition-colors shadow-sm"
                            >
                                Load Older Activity
                            </button>
                        </div>
                    </div>
                </div>
                <div
                    class="lg:w-80 w-full flex-shrink-0 order-first lg:order-last"
                >
                    <div
                        class="bg-indigo text-white rounded-3xl p-6 shadow-floating sticky top-32 overflow-hidden relative"
                    >
                        <div
                            class="absolute right-0 top-0 w-32 h-32 bg-white opacity-10 rounded-full -mr-10 -mt-10 pointer-events-none"
                        >
                        </div>
                        <div
                            class="absolute left-0 bottom-0 w-24 h-24 bg-orange opacity-20 rounded-full -ml-8 -mb-8 pointer-events-none"
                        >
                        </div>
                        <h3
                            class="text-lg font-bold mb-6 flex items-center gap-2 relative z-10"
                        >
                            <span class="material-symbols-outlined"
                                >analytics</span
                            >
                            Quick Stats
                        </h3>
                        <div class="space-y-6 relative z-10">
                            <div>
                                <p
                                    class="text-indigo-200 text-xs font-bold uppercase tracking-widest mb-1"
                                >
                                    Total Spent
                                </p>
                                <p
                                    class="font-mono text-4xl font-bold tracking-tight text-white"
                                >
                                    $254.50
                                </p>
                                <div
                                    class="w-full bg-indigo-dark/50 h-1.5 rounded-full mt-2 overflow-hidden"
                                >
                                    <div
                                        class="bg-orange h-full rounded-full"
                                        style="width: 45%"
                                    >
                                    </div>
                                </div>
                            </div>
                            <div>
                                <p
                                    class="text-indigo-200 text-xs font-bold uppercase tracking-widest mb-1"
                                >
                                    Total Earned
                                </p>
                                <p
                                    class="font-mono text-4xl font-bold tracking-tight text-teal-light"
                                >
                                    +$1,500.00
                                </p>
                                <div
                                    class="w-full bg-indigo-dark/50 h-1.5 rounded-full mt-2 overflow-hidden"
                                >
                                    <div
                                        class="bg-teal h-full rounded-full"
                                        style="width: 85%"
                                    >
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div
                            class="mt-8 pt-6 border-t border-white/10 relative z-10"
                        >
                            <p class="text-indigo-200 text-sm mb-3">
                                Viewing <span class="text-white font-bold"
                                    >All Transactions</span
                                > for August.
                            </p>
                            <button
                                class="w-full bg-white text-indigo font-bold py-3 rounded-xl hover:bg-indigo-50 transition-colors shadow-tactile hover:shadow-tactile-hover hover:translate-y-[1px]"
                            >
                                Export Report
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </main>
    <Footer />
</Layout>
