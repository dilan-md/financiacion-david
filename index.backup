    <script>
        function switchTab(tabId) {
            // Hide all views
            const views = document.querySelectorAll('.view-section');
            views.forEach(view => {
                view.classList.add('hidden');
            });

            // Show selected view
            document.getElementById('view-' + tabId).classList.remove('hidden');

            // Reset all nav links styles
            const navLinks = document.querySelectorAll('.nav-link');
            navLinks.forEach(link => {
                link.classList.remove('text-indigo', 'border-indigo');
                link.classList.add('text-slate-400', 'border-transparent');
            });

            // Set active nav link style for desktop
            const activeLink = document.getElementById('nav-' + tabId);
            if (activeLink) {
                activeLink.classList.remove('text-slate-400', 'border-transparent');
                activeLink.classList.add('text-indigo', 'border-indigo');
            }

            // Set active nav link style for mobile
            const activeMobileLink = document.getElementById('nav-mobile-' + tabId);
            if (activeMobileLink) {
                activeMobileLink.classList.remove('text-slate-400', 'border-transparent');
                activeMobileLink.classList.add('text-indigo', 'border-indigo');
            }

            // Scroll to top smoothly
            window.scrollTo({ top: 0, behavior: 'smooth' });
        }
    </script>
    <style>
        .animate-fade-in {
            animation: fadeIn 0.3s ease-in-out;
        }

        @keyframes fadeIn {
            from {
                opacity: 0;
                transform: translateY(10px);
            }

            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        .scrollbar-hide::-webkit-scrollbar {
            display: none;
        }

        .scrollbar-hide {
            -ms-overflow-style: none;
            scrollbar-width: none;
        }
    </style>
</body>

</html>